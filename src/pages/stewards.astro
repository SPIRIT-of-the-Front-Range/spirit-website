---
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import StewardCard from '../components/editorial/StewardCard.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import PullQuote from '../components/editorial/PullQuote.astro';
import { getCollection, render } from 'astro:content';

const stewards = (await getCollection('stewards')).sort((a, b) => a.data.order - b.data.order);
const renderedStewards = await Promise.all(
  stewards.map(async s => {
    const { Content } = await render(s);
    return { entry: s, Content };
  })
);
const BASE = import.meta.env.BASE_URL;
---

<Base title="Stewards" description="The Transitional Stewards Team — the activating team for Spirit of the Front Range.">

  <PageCover
    folio="04"
    sectionLabel="Stewards"
    eyebrow="On who is doing the work, and why"
    title="The Transitional"
    italicTitle="Stewards Team."
    subtitle="To grow the bones of the foundation. We are an activating and scaffolding team whose aim is to cultivate a Commons that eventually governs itself."
    imageSrc={`${import.meta.env.BASE_URL}images/community/gathering-06.jpg`}
    imageAlt="Hands holding and blessing a person during a Listeners' Council — black and white intimate portrait."
    plate=""
    plateCaption="Listeners' Council · blessing"
    treatment="duotone-ink"
    brightness={0.62}
  />

  {/* Manifesto spread */}
  <Spread folio="04.1" section="Manifesto" bg="bone">
    <div class="px-5 lg:px-12 py-section">
      <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

        <div class="col-span-12 lg:col-span-4 lg:sticky lg:top-8 self-start space-y-6">
          <span class="folio-num text-7xl text-clay-deep">04.i</span>
          <Marginalia number="01">
            <strong>Transitional</strong> is not a hedge. It is a commitment: Spirit's leadership is designed to be replaced by the community it serves.
          </Marginalia>
          <Marginalia>
            The team distinguishes the <em>act</em> of stewardship, the <em>responsibility</em> of stewardship, and the <em>role</em> of <em>Steward</em>. These are not the same thing.
          </Marginalia>
        </div>

        <div class="col-span-12 lg:col-span-8">
          <div class="rule-double mb-6"></div>
          <p class="eyebrow mb-3">An activating team</p>
          <h2 class="display-l text-ink break-words leading-[0.95] mb-8">
            We are a small team at the <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">beginning of something</span>, and we do not have all the answers.
          </h2>

          <div class="text-body-lg text-ink leading-snug space-y-5 max-w-3xl dropcap">
            <p>
              SPIRIT operates through Transitional Stewards — an activating and scaffolding team whose aim is to cultivate a commons that eventually governs itself. The organization's explicit goal is building something that <strong>no longer needs us in our current roles.</strong>
            </p>
            <p>
              The current team holds five organizing functions: <strong>Stewarding</strong>, <strong>Governance</strong>, <strong>Creative</strong>, <strong>Community Networking</strong>, and <strong>Tech Infrastructure</strong>. Each is a circle in the larger Stewardship Council, with the authority to make decisions in its domain by consent rather than majority vote.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Spread>

  {/* Steward Grid */}
  <Spread folio="04.2" section="The Team" bg="bone-pale" class="border-y border-ink">
    <div class="px-5 lg:px-12 py-section">
      <div class="rule-bold mb-6"></div>
      <div class="flex items-baseline justify-between gap-4 flex-wrap mb-10">
        <div>
          <p class="eyebrow eyebrow-creek mb-2">★ The team</p>
          <h2 class="display-m text-ink leading-[1.0]">Five circles, five stewards.</h2>
        </div>
        <p class="caption text-shadow">N = 5 · As of {new Date().toLocaleString('en-US', { month: 'short', year: 'numeric' })}</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {renderedStewards.map(({ entry, Content }, i) => (
          <StewardCard
            number={String(i + 1).padStart(2, '0')}
            name={entry.data.name}
            role={entry.data.role}
            email={entry.data.email}
          >
            <Content />
          </StewardCard>
        ))}
      </div>
    </div>
  </Spread>

  {/* Pull quote */}
  <div class="bg-bone py-section">
    <div class="container-narrow">
      <PullQuote attribution="From the governance design synthesis · April 2026">
        The board appoints the stewards. The stewards appoint the circle leads. The circle leads appoint the project leads. We're doing appointments, not elections — for Spirit. The Commons, by contrast, will use election.
      </PullQuote>
    </div>
  </div>

  {/* Future board */}
  <Spread folio="04.3" section="A Future Board" bg="bone-deep" class="border-y border-ink">
    <div class="px-5 lg:px-12 py-section">
      <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">
        <div class="col-span-12 lg:col-span-5">
          <span class="folio-num text-7xl text-clay-deep mb-6 block">04.iii</span>
          <p class="eyebrow mb-4">A future board</p>
          <h2 class="display-m text-ink leading-[1.0]">
            Eventually, the board <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">will not look like us.</span>
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-7 text-body-lg text-ink leading-snug space-y-4">
          <p>
            Eventually, the Board of SPIRIT — we pray — will be comprised of <strong>Indigenous leaders, elders, and devoted civic stewards</strong> who represent the demography of this bioregion.
          </p>
          <p>
            For now, the activating team is made up of Transitional Stewards who aim to become regular commoners in the Commons with no more say than anyone else. The institution exists to serve the Commons, not to perpetuate itself.
          </p>
        </div>
      </div>
    </div>
  </Spread>

</Base>

<style>
  .py-section { padding-block: var(--spacing-section); }
</style>
