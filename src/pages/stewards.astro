---
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import StewardCard from '../components/editorial/StewardCard.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import PullQuote from '../components/editorial/PullQuote.astro';
import { getCollection, render, getEntry } from 'astro:content';
import { basePath } from '../lib/paths';
import { mdToHtml, mdToInline } from '../lib/markdown';

const entry = await getEntry('pages', 'stewards');
if (!entry) throw new Error('Missing src/content/pages/stewards.md');
const { seo, cover, spreads, pullQuote } = entry.data;

const stewards = (await getCollection('stewards')).sort((a, b) => a.data.order - b.data.order);
const renderedStewards = await Promise.all(
  stewards.map(async s => {
    const { Content } = await render(s);
    return { entry: s, Content };
  })
);

const asOfLabel = new Date().toLocaleString('en-US', { month: 'short', year: 'numeric' });
---

<Base title={seo.title} description={seo.description}>

  <PageCover
    folio="04"
    sectionLabel="Stewards"
    eyebrow={cover.eyebrow}
    title={cover.title}
    italicTitle={cover.italicTitle}
    subtitle={cover.subtitle}
    imageSrc={basePath(cover.imageSrc)}
    imageAlt={cover.imageAlt}
    plate=""
    plateCaption={cover.plateCaption}
    treatment={cover.treatment}
    brightness={cover.brightness}
  />

  {/* Manifesto spread */}
  {spreads?.manifesto && (
    <Spread folio="04.1" section={spreads.manifesto.sectionLabel} bg="bone">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

          <div class="col-span-12 lg:col-span-4 lg:sticky lg:top-8 self-start space-y-6">
            <span class="folio-num text-7xl text-clay-deep">04.i</span>
            <Marginalia number="01">
              <Fragment set:html={mdToInline(spreads.manifesto.marginaliaPrimary)} />
            </Marginalia>
            <Marginalia>
              <Fragment set:html={mdToInline(spreads.manifesto.marginaliaSecondary)} />
            </Marginalia>
          </div>

          <div class="col-span-12 lg:col-span-8">
            <div class="rule-double mb-6"></div>
            <p class="eyebrow mb-3">{spreads.manifesto.eyebrow}</p>
            <h2 class="display-l text-ink break-words leading-[0.95] mb-8">
              {spreads.manifesto.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.manifesto.italicHeading}</span>{spreads.manifesto.headingTail && (<Fragment>{spreads.manifesto.headingTail}</Fragment>)}
            </h2>

            <div class="text-body-lg text-ink leading-snug space-y-5 max-w-3xl dropcap">
              <Fragment set:html={mdToHtml(spreads.manifesto.body)} />
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* Steward Grid */}
  {spreads?.team && (
    <Spread folio="04.2" section={spreads.team.sectionLabel} bg="bone-pale" class="border-y border-ink">
      <div class="px-5 lg:px-12 py-section">
        <div class="rule-bold mb-6"></div>
        <div class="flex items-baseline justify-between gap-4 flex-wrap mb-10">
          <div>
            <p class="eyebrow eyebrow-creek mb-2">{spreads.team.eyebrow}</p>
            <h2 class="display-m text-ink leading-[1.0]">{spreads.team.heading}</h2>
          </div>
          <p class="caption text-shadow">{spreads.team.countLabel} · As of {asOfLabel}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {renderedStewards.map(({ entry: s, Content }, i) => (
            <StewardCard
              number={String(i + 1).padStart(2, '0')}
              name={s.data.name}
              role={s.data.role}
              email={s.data.email}
            >
              <Content />
            </StewardCard>
          ))}
        </div>
      </div>
    </Spread>
  )}

  {/* Pull quote */}
  {pullQuote && (
    <div class="bg-bone py-section">
      <div class="container-narrow">
        <PullQuote attribution={pullQuote.attribution}>
          {pullQuote.text}
        </PullQuote>
      </div>
    </div>
  )}

  {/* Future board */}
  {spreads?.futureBoard && (
    <Spread folio="04.3" section={spreads.futureBoard.sectionLabel} bg="bone-deep" class="border-y border-ink">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">
          <div class="col-span-12 lg:col-span-5">
            <span class="folio-num text-7xl text-clay-deep mb-6 block">04.iii</span>
            <p class="eyebrow mb-4">{spreads.futureBoard.eyebrow}</p>
            <h2 class="display-m text-ink leading-[1.0]">
              {spreads.futureBoard.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.futureBoard.italicHeading}</span>
            </h2>
          </div>
          <div class="col-span-12 lg:col-span-7 text-body-lg text-ink leading-snug space-y-4">
            <Fragment set:html={mdToHtml(spreads.futureBoard.body)} />
          </div>
        </div>
      </div>
    </Spread>
  )}

</Base>

<style>
  .py-section { padding-block: var(--spacing-section); }
</style>
