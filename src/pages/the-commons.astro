---
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import PullQuote from '../components/editorial/PullQuote.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import BioregionMap from '../components/interactive/BioregionMap.astro';
import { getEntry } from 'astro:content';
import { basePath, resolveLink } from '../lib/paths';
import { mdToHtml, mdToInline } from '../lib/markdown';

const entry = await getEntry('pages', 'the-commons');
if (!entry) throw new Error('Missing src/content/pages/the-commons.md');
const { seo, cover, spreads, pullQuote } = entry.data;

// Per-glossary-term num-badge colors: literal class strings for Tailwind.
const numBadgeColor = {
  clay: 'text-clay-deep',
  creek: 'text-creek-deep',
  sage: 'text-sage-deep',
  grass: 'text-grass-deep',
} as const;

const relationshipLink = spreads?.relationship ? resolveLink(spreads.relationship.ctaHref) : null;
---

<Base title={seo.title} description={seo.description}>

  <PageCover
    folio="03"
    sectionLabel="The Commons"
    eyebrow={cover.eyebrow}
    title={cover.title}
    italicTitle={cover.italicTitle}
    subtitle={cover.subtitle}
    imageSrc={basePath(cover.imageSrc)}
    imageAlt={cover.imageAlt}
    plate=""
    plateCaption={cover.plateCaption}
    treatment={cover.treatment}
    brightness={cover.brightness}
  />

  {/* IN BRIEF + MAP */}
  {spreads?.inBrief && (
    <Spread folio="03.1" section={spreads.inBrief.sectionLabel} bg="bone">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-14 items-start">

          <div class="col-span-12 lg:col-span-7">
            <span class="folio-num text-7xl text-creek-deep mb-6 block">03.i</span>
            <div class="rule-double mb-6"></div>
            <p class="eyebrow eyebrow-creek mb-3">{spreads.inBrief.eyebrow}</p>
            <h2 class="display-l text-ink break-words leading-[0.95] mb-6">
              {spreads.inBrief.heading} <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{spreads.inBrief.italicHeading}</span>
            </h2>
            <div class="text-body-lg text-ink leading-snug space-y-4 dropcap max-w-2xl">
              <Fragment set:html={mdToHtml(spreads.inBrief.body)} />
            </div>
          </div>

          <div class="col-span-12 lg:col-span-5">
            <BioregionMap />
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* GLOSSARY SPREAD */}
  {spreads?.glossary && (
    <Spread folio="03.2" section={spreads.glossary.sectionLabel} bg="bone-pale" class="border-y border-ink">
      <div class="px-5 lg:px-12 py-section">
        <div class="rule-bold mb-6"></div>
        <div class="grid grid-cols-12 gap-6 mb-12 items-end">
          <div class="col-span-12 lg:col-span-7">
            <p class="eyebrow mb-3">{spreads.glossary.eyebrow}</p>
            <h2 class="display-l text-ink break-words leading-[0.95]">
              {spreads.glossary.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.glossary.italicHeading}</span>
            </h2>
          </div>
          <div class="col-span-12 lg:col-span-5 lg:pl-8 lg:border-l border-ink">
            <p class="caption text-shadow">{spreads.glossary.caption}</p>
          </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-x-12 gap-y-12">
          {spreads.glossary.terms.map((t) => (
            <article>
              <p class={`num-badge ${numBadgeColor[t.color]} mb-2`}>{t.number}</p>
              <h3 class="font-display font-bold text-h2 text-ink leading-tight mb-1">{t.term}</h3>
              <p class="caption-italic mb-3">{t.pronunciation}</p>
              <div class="text-body text-ink leading-relaxed glossary-body">
                <Fragment set:html={mdToInline(t.body)} />
              </div>
            </article>
          ))}
        </div>
      </div>
    </Spread>
  )}

  {/* PULL QUOTE */}
  {pullQuote && (
    <div class="bg-bone py-section">
      <div class="container-narrow">
        <PullQuote>
          {pullQuote.text}
        </PullQuote>
      </div>
    </div>
  )}

  {/* RELATIONSHIP — Spirit / Commons */}
  {spreads?.relationship && relationshipLink && (
    <Spread folio="03.3" section={spreads.relationship.sectionLabel} bg="bone" class="border-t border-ink">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

          <div class="col-span-12 lg:col-span-4">
            <span class="folio-num text-7xl text-clay-deep mb-6 block">03.iii</span>
            <Marginalia number="05">
              <Fragment set:html={mdToInline(spreads.relationship.marginalia)} />
            </Marginalia>
          </div>

          <div class="col-span-12 lg:col-span-8">
            <div class="rule-double mb-6"></div>
            <p class="eyebrow mb-3">{spreads.relationship.eyebrow}</p>
            <h2 class="display-l text-ink break-words leading-[0.95] mb-10">
              {spreads.relationship.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.relationship.italicHeading}</span>
            </h2>

            <div class="grid sm:grid-cols-2 gap-6">
              <div class="paper p-6">
                <p class="eyebrow eyebrow-clay mb-3">{spreads.relationship.spiritCard.eyebrow}</p>
                <p class="font-display font-bold text-h3 text-ink mb-3 leading-tight">{spreads.relationship.spiritCard.title}</p>
                <ul class="space-y-2 text-body text-shadow">
                  {spreads.relationship.spiritCard.items.map((item) => (
                    <li>● {item}</li>
                  ))}
                </ul>
              </div>
              <div class="paper p-6">
                <p class="eyebrow eyebrow-creek mb-3">{spreads.relationship.commonsCard.eyebrow}</p>
                <p class="font-display font-bold text-h3 text-ink mb-3 leading-tight">{spreads.relationship.commonsCard.title}</p>
                <ul class="space-y-2 text-body text-shadow">
                  {spreads.relationship.commonsCard.items.map((item) => (
                    <li>● {item}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="mt-8">
              <a href={relationshipLink.href} rel={relationshipLink.rel} class="btn-line">{spreads.relationship.ctaLabel}</a>
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

</Base>

<style>
  .py-section { padding-block: var(--spacing-section); }
</style>
