---
import Base from '../layouts/Base.astro';
import Spread from '../components/editorial/Spread.astro';
import Plate from '../components/editorial/Plate.astro';
import QuotePhoto from '../components/editorial/QuotePhoto.astro';
import Annotation from '../components/editorial/Annotation.astro';
import { getCollection } from 'astro:content';

const programs = (await getCollection('programs')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="SPIRIT of the Front Range"
  description="A bioregional backbone non-profit supporting local resilience and bioregional regeneration along Colorado's Front Range."
>

  {/* ====================================================== */}
  {/* SPREAD A — COVER (photo bleeds edge, sized to fit)     */}
  {/* ====================================================== */}
  <Spread folio="01" section="Cover" bg="image" minHeight="auto" class="cover-spread overflow-hidden">

    {/* Background photo — full bleed */}
    <div class="absolute inset-0 photo duotone-cover" aria-hidden="true">
      <img src="/images/community/gathering-04.jpg" alt="" class="w-full h-full object-cover ken-burns" loading="eager" />
    </div>

    {/* Vignette — darken top + bottom for type legibility */}
    <div class="absolute inset-0 pointer-events-none"
         style="background:
           linear-gradient(180deg, rgba(31,30,27,0.55) 0%, rgba(31,30,27,0.18) 22%, rgba(31,30,27,0.10) 50%, rgba(31,30,27,0.78) 92%, rgba(31,30,27,0.92) 100%);"></div>

    {/* Cover content — title top-left, content bottom-right */}
    <div class="relative px-5 lg:px-12 pt-10 lg:pt-14 pb-8 lg:pb-10 flex flex-col" style="min-height: clamp(620px, 80svh, 1200px);">

      {/* Title — top-left */}
      <div class="anim-fade-up max-w-7xl">
        <p class="eyebrow mb-4" style="color: rgba(242,234,216,0.95); letter-spacing: 0.2em;">★ We care for what we share</p>
        <h1 class="leading-[0.84]" style="color: #F7EFD8; font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 1.6rem + 7vw, 11.5rem); letter-spacing: -0.035em;">
          <span class="block">SPIRIT <span class="font-serif italic font-light tracking-tighter" style="font-weight:300; font-size: 0.55em; vertical-align: 0.34em; letter-spacing: -0.04em;">of the</span></span>
          <span class="block italic font-serif font-light tracking-tighter" style="font-weight:300;">Front Range.</span>
        </h1>
      </div>

      {/* Spacer */}
      <div class="flex-1 min-h-[2rem]"></div>

      {/* Bottom row: tagline + CTAs + TOC */}
      <div class="grid grid-cols-12 gap-6 lg:gap-10 items-end anim-fade-up" style="animation-delay:280ms;">

        {/* Tagline + CTAs (left bottom) */}
        <div class="col-span-12 lg:col-span-7">
          <p class="font-serif italic leading-tight text-bone-pale mb-5 max-w-xl" style="font-size: clamp(1.05rem, 0.95rem + 0.5vw, 1.4rem); color: #F7EFD8;">
            A bioregional backbone non-profit mobilizing neighborhoods for real solidarity, ecological care, and the founding of a Front Range Commons.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/the-commons/" class="btn-ink" style="background: #F2EAD8; color: #1F1E1B; border-color: #F2EAD8;">★ Read the Almanac</a>
            <a href="/donate/" class="btn-line" style="border-color: rgba(242,234,216,0.85); color: #F7EFD8;">◇ Fund</a>
          </div>
        </div>

        {/* Interactive jump nav (right bottom) */}
        <aside class="col-span-12 lg:col-span-5 lg:pl-6 lg:border-l border-bone-pale/40">
          <p class="block mb-3 font-bold text-[10px] font-mono uppercase tracking-[0.22em]" style="color:#E8B58A;">★ Jump to —</p>
          <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5 text-[10px] font-mono uppercase tracking-[0.16em]">
            <li><a href="#philosophy" class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95); text-decoration-color: rgba(232,181,138,0.6);"><span style="color:#E8B58A;">02 ·</span> <span class="group-hover:translate-x-0.5 transition-transform">Philosophy</span></a></li>
            <li><a href="#programs" class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95);"><span style="color:#E8B58A;">06 ·</span> <span class="group-hover:translate-x-0.5 transition-transform">Programs</span></a></li>
            <li><a href="#steward-note" class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95);"><span style="color:#E8B58A;">03 ·</span> <span class="group-hover:translate-x-0.5 transition-transform">A Steward's note</span></a></li>
            <li><a href="#commons" class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95);"><span style="color:#E8B58A;">07 ·</span> <span class="group-hover:translate-x-0.5 transition-transform">The Commons</span></a></li>
            <li><a href="#vessel" class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95);"><span style="color:#E8B58A;">04 ·</span> <span class="group-hover:translate-x-0.5 transition-transform">The Vessel</span></a></li>
            <li><a href="#funding" class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95);"><span style="color:#E8B58A;">08 ·</span> <span class="group-hover:translate-x-0.5 transition-transform">Funding</span></a></li>
            <li><a href="#pillars" class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95);"><span style="color:#E8B58A;">05 ·</span> <span class="group-hover:translate-x-0.5 transition-transform">Four Pillars</span></a></li>
          </ul>
        </aside>
      </div>

      {/* Image caption — final strip */}
      <div class="mt-8 pt-3 border-t border-bone-pale/40 grid grid-cols-12 gap-3 caption" style="color: rgba(247,239,216,0.85);">
        <span class="col-span-4 lg:col-span-3"><span style="color:#E8B58A;">●</span> Cover</span>
        <span class="col-span-4 lg:col-span-6 text-center hidden sm:block">Solidarity Supper · August · Boulder</span>
        <span class="col-span-4 lg:col-span-3 text-right opacity-75">photographed for SPIRIT · 2024</span>
      </div>
    </div>

    {/* Hand-drawn ornament */}
    <Annotation variant="star" class="absolute top-8 right-8 w-10 h-10 hidden lg:block" color="rgba(242,234,216,0.55)" />

    <style>
      .duotone-cover img { filter: contrast(1.05) saturate(0.85) sepia(0.10) brightness(0.78); }
    </style>
  </Spread>

  {/* ====================================================== */}
  {/* SPREAD B — PHILOSOPHY (full viewport split)             */}
  {/* Photo floor-to-ceiling on right, dense type left       */}
  {/* ====================================================== */}
  <Spread folio="02" section="Philosophy" bg="bone" minHeight="100svh" class="philosophy-spread" id="philosophy">

    <div class="grid grid-cols-12 gap-0 min-h-[100svh] relative">

      {/* Left margin: section number printed on side */}
      <div class="hidden lg:flex col-span-1 border-r border-ink flex-col items-center justify-between py-10 px-2 bg-bone">
        <span class="folio-num text-9xl text-clay-deep leading-[0.8]">02</span>
        <div class="caption text-shadow [writing-mode:vertical-rl] rotate-180 tracking-[0.3em]">PHILOSOPHY · A CREED OF BELONGING · §</div>
        <span class="caption text-shadow">↓ continued</span>
      </div>

      {/* Body text — middle 6 cols */}
      <div class="col-span-12 lg:col-span-6 px-5 lg:px-10 py-12 lg:py-20 relative border-r border-ink bg-bone">
        <div class="lg:hidden mb-8 flex items-baseline gap-3">
          <span class="folio-num text-6xl text-clay-deep">02</span>
          <span class="eyebrow">II · Philosophy</span>
        </div>

        <div class="rule-double mb-8"></div>

        <h2 class="display-l text-ink mb-10 leading-[0.95]">
          We belong to <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">more places</span> than we have names for.
        </h2>

        <div class="body-cols-2 text-body text-ink leading-snug">
          <p class="dropcap">
            Here in the Front Range of the Rocky Mountains, we live in our homes, within our different neighborhoods, and we also live in an ecology, in a bioregion, in a watershed.
          </p>
          <p class="mt-4">
            We drink from an aquifer shared by every being around us. The mountain air we each breathe knows nothing of county lines. Sharing this place, we are <strong>all connected to each other</strong> through the lands that hold us here.
          </p>
          <p class="mt-4">
            Core to the philosophy of SPIRIT is the recognition that the most meaningful unit of collective life is not the county or the state — it is the bioregion. A living landscape defined by watershed, ecology, and the human and other-than-human communities nested within them.
          </p>
          <p class="mt-4 font-serif italic text-clay-deep" style="font-size: 1.18rem; line-height: 1.4;">
            Nature is what we are, just like a forest, a high-mountain desert, or a wetland.
          </p>
        </div>

        {/* Marginalia at bottom of column */}
        <div class="mt-12 grid grid-cols-12 gap-3 items-baseline pt-5 border-t border-rule">
          <span class="col-span-2 caption text-clay-deep">N° 02.1</span>
          <span class="col-span-10 caption">If you live on the Earth, you are sharing a home.</span>
        </div>

      </div>

      {/* Photo — right 5 cols, floor to ceiling */}
      <div class="col-span-12 lg:col-span-5 relative bg-ink min-h-[60svh] lg:min-h-0">
        <div class="absolute inset-0 photo">
          <img
            src="/images/community/gathering-01.jpg"
            alt="A creek at dusk in a mountain valley with fall-yellow aspen reflected in still water."
            class="w-full h-full object-cover ken-burns"
            loading="lazy"
          />
        </div>
        {/* Caption strip at bottom of image */}
        <div class="absolute bottom-0 left-0 right-0 p-4 lg:p-6 bg-gradient-to-t from-ink/90 via-ink/60 to-transparent text-bone-pale">
          <div class="flex items-baseline justify-between gap-3 caption text-bone-pale">
            <span style="color:#E8B58A;">Plate II</span>
            <span class="hidden sm:block flex-1 text-center">creek above Nederland · early autumn</span>
            <span>↑ p. 2</span>
          </div>
        </div>

        {/* Tiny inset diagram in top-right */}
        <div class="absolute top-4 right-4 lg:top-6 lg:right-6 bg-bone p-2 border border-ink shadow-[3px_3px_0_0_rgba(31,30,27,0.85)] rotate-[-3deg]" style="width: 110px;">
          <svg viewBox="0 0 100 60" class="w-full" aria-hidden="true">
            <path d="M 0 50 L 25 28 L 40 36 L 55 18 L 75 32 L 100 50" fill="none" stroke="#1F1E1B" stroke-width="1.4"/>
            <path d="M 50 50 Q 60 40, 70 45 T 100 42" fill="none" stroke="#5C7E8A" stroke-width="1.2"/>
          </svg>
          <p class="caption text-[8px] text-shadow tracking-[0.16em] mt-1 text-center">FIG. ◊  watershed</p>
        </div>
      </div>
    </div>
  </Spread>

  {/* ====================================================== */}
  {/* SPREAD C — STEWARD'S NOTE (pull quote spread)           */}
  {/* ====================================================== */}
  <section id="steward-note" class="relative" style="scroll-margin-top: 6rem;">
    <QuotePhoto
      src="/images/community/gathering-11.jpg"
      alt="Sunset over the silhouetted Front Range with sun rays radiating through the mountain ridge."
      treatment="duotone-clay-deep"
      attribution="Benjamin Life · Governance Director"
      align="left"
      height="100svh"
      folio="03"
    >
      Our mutual relationship to where we live <em class="font-serif font-light">implies</em> our mutual responsibility for that place. This relationship cannot be enclosed because it is, by definition, <em class="font-serif font-light">a commons</em>.
    </QuotePhoto>
    {/* Section label printed on top-left */}
    <div class="absolute top-4 left-4 lg:top-7 lg:left-10 z-10 caption text-bone-pale/80">
      A Steward's note
    </div>
    <div class="absolute top-12 left-4 lg:top-16 lg:left-10 z-10 caption text-bone-pale/60">
      ↳ on the impossibility of enclosure
    </div>
  </section>

  {/* ====================================================== */}
  {/* SPREAD D — THE VESSEL (newspaper-dense spread)          */}
  {/* ====================================================== */}
  <Spread folio="04" section="The Vessel" bg="bone-pale" class="vessel-spread border-y-2 border-ink" id="vessel">
    <div class="px-5 lg:px-10 pt-12 lg:pt-20 pb-16 lg:pb-24">

      {/* Top contact-sheet strip */}
      <div class="grid grid-cols-3 lg:grid-cols-6 gap-2 lg:gap-3 mb-10 lg:mb-14">
        {[2, 5, 7, 8, 9, 12].map((n, i) => (
          <div class="contact-thumb relative aspect-[4/3] photo">
            <img src={`/images/community/gathering-${String(n).padStart(2,'0')}.jpg`} alt="" class="w-full h-full object-cover" loading="lazy" />
            <span class="absolute bottom-1 left-1.5 caption text-bone-pale/95 text-[8px] tracking-[0.18em]">P. {String(i+1).padStart(2,'0')}</span>
          </div>
        ))}
      </div>

      <div class="rule-triple mb-8"></div>

      {/* Top header — h1 left, diagram top-right level with title */}
      <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start mb-12">
        <div class="col-span-12 lg:col-span-8">
          <div class="flex items-baseline gap-5 mb-3 flex-wrap">
            <span class="folio-num text-5xl lg:text-6xl text-clay-deep">04</span>
            <p class="eyebrow">The Vessel</p>
          </div>
          <h2 class="display-l text-ink leading-[0.95]">
            A 501(c)(3) building <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">connective tissue</span> for bioregional coordination.
          </h2>
        </div>

        {/* Diagram — Spirit & Commons relationship — top right, level with title */}
        <aside class="col-span-12 lg:col-span-4">
          <div class="diagram-box border-2 border-ink p-4 bg-bone relative">
            <p class="caption text-clay-deep mb-3">Fig. 04 · the lattice</p>
            <svg viewBox="0 0 240 150" class="w-full" aria-hidden="true">
              <text x="120" y="22" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" font-weight="700" fill="#7E4226" letter-spacing="2">FEEDS &amp; PROTECTS</text>
              <path d="M 50 30 L 50 36 L 190 36 L 190 30" fill="none" stroke="#B8704D" stroke-width="1.2"/>
              <path d="M 116 36 L 120 42 L 124 36" fill="#B8704D"/>

              <rect x="10" y="60" width="90" height="74" fill="none" stroke="#1F1E1B" stroke-width="1.6"/>
              <text x="55" y="86" text-anchor="middle" font-family="Bricolage Grotesque Variable, sans-serif" font-size="13" font-weight="700" fill="#1F1E1B">SPIRIT</text>
              <text x="55" y="102" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4A4A45">501(c)(3)</text>
              <text x="55" y="116" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4A4A45">the lattice</text>

              <circle cx="180" cy="97" r="40" fill="none" stroke="#5C7E8A" stroke-width="1.6"/>
              <text x="180" y="94" text-anchor="middle" font-family="Bricolage Grotesque Variable, sans-serif" font-size="11" font-weight="700" fill="#1F1E1B">COMMONS</text>
              <text x="180" y="108" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6.5" fill="#4A4A45">member-governed</text>

              <text x="10" y="148" font-family="JetBrains Mono, monospace" font-size="6.5" fill="#4A4A45">↳ does not control · does not enclose</text>
            </svg>
          </div>
        </aside>
      </div>

      {/* Body — 3-col text left, editor's note + language note right */}
      <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start">

        {/* Body text in 3 columns */}
        <div class="col-span-12 lg:col-span-8">
          <div class="body-cols-3 text-body text-ink leading-snug">
            <p>
              <strong>This institution exists to serve the Commons, not to perpetuate itself.</strong> We are a non-profit acting as the vessel that interfaces with the existing world of foundations, governments, and formal partnerships.
            </p>
            <p class="mt-3">
              We are a transitional stewardship team handling the institutional work: education and programming, grant management, fiscal sponsorship, and legal operations. All of this aims toward the establishment of the Front Range Commons — a parallel, member-governed network for cultural and ecological stewardship and community-led resource allocation.
            </p>
            <p class="mt-3">
              Spirit operates by sociocratic consent inside its <em class="text-clay-deep">Stewardship Council</em>. Five circles — Admin, Culture, Story, Programming, Finance — hold the weekly work. The Board's role is reduced to legal oversight only; the operational center lives at the Council.
            </p>
            <p class="mt-3">
              <strong>The team is transitional.</strong> Eventually, we hope, the Board will be comprised of Indigenous leaders, elders, and devoted civic stewards who represent the demography of this bioregion. The aim is to be replaced.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/stewards/" class="btn-line">◇ Meet the Stewards</a>
            <a href="/mission/" class="btn-line">◇ Strategy &amp; Theory</a>
          </div>
        </div>

        {/* Right side: editor's note + language note (was previously below diagram) */}
        <aside class="col-span-12 lg:col-span-4 space-y-6 lg:border-l border-ink lg:pl-6">
          <div>
            <p class="sticker sticker-clay inline-block mb-3">Editor's note</p>
            <p class="text-body text-shadow leading-snug">
              We are neither the Commons nor a substitute for it. Spirit is the institutional <em class="font-serif italic">vessel</em>: it holds the legal weight so that the Commons can hold the practice.
            </p>
          </div>

          <div class="rule"></div>

          <div>
            <p class="sticker sticker-clay inline-block mb-3">A note on language</p>
            <p class="font-serif italic text-body-lg leading-snug text-ink">
              "There's a difference between the act of stewardship, the responsibility of stewardship, and the role of <em>steward</em>."
            </p>
            <p class="caption mt-2">— Benjamin Life · April 2026</p>
          </div>
        </aside>
      </div>
    </div>
  </Spread>

  {/* ====================================================== */}
  {/* SPREAD E — FOUR PILLARS (catalog spread, 2x2 grid)      */}
  {/* ====================================================== */}
  <Spread folio="05" section="Four Pillars" bg="bone" class="pillars-spread" id="pillars">
    <div class="px-5 lg:px-10 pt-16 lg:pt-24 pb-20 lg:pb-32 relative">

      {/* Header */}
      <div class="grid grid-cols-12 gap-6 lg:gap-10 mb-10 lg:mb-12 items-end">
        <div class="col-span-12 lg:col-span-7">
          <p class="eyebrow mb-3">Section V · A Catalog of Pillars</p>
          <h2 class="display-l text-ink leading-[0.92]">
            Four threads, <span class="italic font-serif font-light" style="font-weight:300;">braided into one weave.</span>
          </h2>
        </div>
        <div class="col-span-12 lg:col-span-5 lg:pl-8 lg:border-l border-ink">
          <p class="text-body text-shadow leading-snug">
            Each pillar is a strategic thread organizing Spirit's activity. They are not separable — every program touches all four — but naming them makes the work <em class="text-clay-deep">legible</em>.
          </p>
          <p class="caption mt-3 text-shadow">↓ see also p. 06 (programs) for active expressions of each pillar</p>
        </div>
      </div>

      <div class="rule-double mb-12"></div>

      {/* 2x2 catalog grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 lg:gap-x-16 gap-y-12 lg:gap-y-16 relative">

        {/* PILLAR 01 - Allocation */}
        <article class="pillar-cat group flex flex-col">
          <p class="eyebrow text-clay-deep mb-2">Pillar · Allocation</p>
          <div class="flex items-baseline gap-3 mb-5 flex-wrap">
            <span class="folio-num text-3xl lg:text-4xl text-clay-deep leading-none">01</span>
            <h3 class="display-m text-ink leading-[0.92]">Allocation.</h3>
          </div>
          <div class="aspect-[5/3] mb-4 photo duotone-clay">
            <img src="/images/community/gathering-09.jpg" alt="Hands washing freshly-pulled carrots under a stream of water in a garden." loading="lazy" />
          </div>
          <p class="caption text-clay-deep mb-3">— Plate III · harvest, summer</p>
          <p class="text-body text-ink leading-snug mb-4 flex-1">
            Flowing resources to projects that <strong>regenerate our bioregion</strong> through quadratic funding for projects and mutual aid. The first round of allocation is being designed now — community-led, transparently cascaded, with at least <strong>50% of total raise</strong> targeted at programmatic disbursement.
          </p>
          <div class="flex items-baseline gap-3 caption mt-auto pt-3 border-t border-rule">
            <span class="text-clay-deep">★ outcome:</span>
            <span>fairly-distributed care</span>
          </div>
        </article>

        {/* PILLAR 02 - Coordination */}
        <article class="pillar-cat group flex flex-col">
          <p class="eyebrow text-creek-deep mb-2">Pillar · Coordination</p>
          <div class="flex items-baseline gap-3 mb-5 flex-wrap">
            <span class="folio-num text-3xl lg:text-4xl text-creek-deep leading-none">02</span>
            <h3 class="display-m text-ink leading-[0.92]">Coordination.</h3>
          </div>
          <div class="aspect-[5/3] mb-4 photo duotone-creek">
            <img src="/images/community/gathering-07.jpg" alt="A still pond at dusk reflecting trees and dramatic clouds." loading="lazy" />
          </div>
          <p class="caption text-creek-deep mb-3">— Plate IV · pond, Boulder Creek watershed</p>
          <p class="text-body text-ink leading-snug mb-4 flex-1">
            Providing tools for <strong>distributed decision-making and treasuries</strong>. Spirit operates by sociocratic consent inside the Stewardship Council; the Commons will use quadratic voting on grant allocation. Decision-making infrastructure is itself a regenerative practice.
          </p>
          <div class="flex items-baseline gap-3 caption mt-auto pt-3 border-t border-rule">
            <span class="text-creek-deep">★ outcome:</span>
            <span>coherent collective will</span>
          </div>
        </article>

        {/* PILLAR 03 - Belonging */}
        <article class="pillar-cat group flex flex-col">
          <p class="eyebrow text-sage-deep mb-2">Pillar · Belonging</p>
          <div class="flex items-baseline gap-3 mb-5 flex-wrap">
            <span class="folio-num text-3xl lg:text-4xl text-sage-deep leading-none">03</span>
            <h3 class="display-m text-ink leading-[0.92]">Belonging.</h3>
          </div>
          <div class="aspect-[5/3] mb-4 photo duotone-sage">
            <img src="/images/community/gathering-06.jpg" alt="Hands holding and blessing a person during a Listeners' Council." loading="lazy" />
          </div>
          <p class="caption text-sage-deep mb-3">— Plate V · Listeners' Council, blessing</p>
          <p class="text-body text-ink leading-snug mb-4 flex-1">
            Fostering a <strong>shared bioregional identity</strong> through Solidarity Suppers, long walks, and Listeners' Councils. We center community leaders and elders — particularly our Indigenous relatives whose knowledge of this place precedes any of our institutions.
          </p>
          <div class="flex items-baseline gap-3 caption mt-auto pt-3 border-t border-rule">
            <span class="text-sage-deep">★ outcome:</span>
            <span>real, embodied solidarity</span>
          </div>
        </article>

        {/* PILLAR 04 - Culturing */}
        <article class="pillar-cat group flex flex-col">
