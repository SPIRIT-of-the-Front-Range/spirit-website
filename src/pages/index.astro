---
import Base from '../layouts/Base.astro';
import Spread from '../components/editorial/Spread.astro';
import { getCollection, getEntry } from 'astro:content';
import { basePath, resolveLink } from '../lib/paths';
import { mdToHtml, mdToInline } from '../lib/markdown';
import { injectTermTooltips } from '../lib/terms';

const entry = await getEntry('pages', 'home');
if (!entry) throw new Error('Missing src/content/pages/home.md');
const { seo, homeCover, spreads } = entry.data;
if (!homeCover) throw new Error('home.md missing homeCover');

const programs = (await getCollection('programs')).sort((a, b) => a.data.order - b.data.order);
const BASE = import.meta.env.BASE_URL;

// In-page jump nav — labels match the new homepage section order.
const jumpNav = [
  { label: 'What SPIRIT is', href: '#vessel' },
  { label: 'Programs', href: '#programs' },
  { label: 'Four Threads', href: '#pillars' },
  { label: 'What guides us', href: '#ethics' },
  { label: 'The Commons', href: '#commons' },
  { label: 'Glossary', href: '#glossary' },
  { label: 'Donate', href: '#funding' },
];

// Per-pillar Tailwind class strings (literal so Tailwind discovers them).
const pillarTone = {
  clay: { text: 'text-clay-deep', photo: 'duotone-clay' },
  creek: { text: 'text-creek-deep', photo: 'duotone-creek' },
  sage: { text: 'text-sage-deep', photo: 'duotone-sage' },
  grass: { text: 'text-grass-deep', photo: 'duotone-sage' },
} as const;

// Programs teaser tones — first 3 programs use clay/creek/sage on home
const teaserTones = ['clay', 'creek', 'sage'] as const;
const teaserPhotos = ['02', '07', '11'];

const coverPrimary = resolveLink(homeCover.primaryCtaHref);
const coverSecondary = resolveLink(homeCover.secondaryCtaHref);
const vesselPrimary = spreads?.vessel ? resolveLink(spreads.vessel.primaryCtaHref) : null;
const vesselSecondary = spreads?.vessel ? resolveLink(spreads.vessel.secondaryCtaHref) : null;
const programsTeaserCta = spreads?.programsTeaser ? resolveLink(spreads.programsTeaser.ctaHref) : null;
const ethicsTeaserCta = spreads?.ethicsTeaser ? resolveLink(spreads.ethicsTeaser.ctaHref) : null;
const commonsTeaserPrimary = spreads?.commonsTeaser ? resolveLink(spreads.commonsTeaser.primaryCtaHref) : null;
const commonsTeaserSecondary = spreads?.commonsTeaser ? resolveLink(spreads.commonsTeaser.secondaryCtaHref) : null;
const fundingPrimary = spreads?.funding ? resolveLink(spreads.funding.primaryCtaHref) : null;
const fundingSecondary = spreads?.funding ? resolveLink(spreads.funding.secondaryCtaHref) : null;
---

<Base title={seo.title} description={seo.description}>

  {/* ====================================================== */}
  {/* SPREAD 01 — COVER                                       */}
  {/* ====================================================== */}
  <Spread folio="01" section="Cover" bg="image" minHeight="auto" class="cover-spread overflow-hidden">

    <div class="absolute inset-0 photo duotone-cover" aria-hidden="true">
      <img src={basePath(homeCover.imageSrc)} alt={homeCover.imageAlt} class="w-full h-full object-cover ken-burns" loading="eager" />
    </div>

    <div class="absolute inset-0 pointer-events-none"
         style="background:
           linear-gradient(180deg, rgba(31,30,27,0.55) 0%, rgba(31,30,27,0.18) 22%, rgba(31,30,27,0.10) 50%, rgba(31,30,27,0.78) 92%, rgba(31,30,27,0.92) 100%);"></div>

    <div class="relative px-5 lg:px-12 pt-10 lg:pt-14 pb-8 lg:pb-10 flex flex-col" style="min-height: clamp(620px, 80svh, 1200px);">

      <div class="anim-fade-up max-w-7xl">
        <p class="eyebrow mb-4" style="color: rgba(242,234,216,0.95); letter-spacing: 0.2em;">{homeCover.eyebrow}</p>
        <h1 class="leading-[0.84]" style="color: #F7EFD8; font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 1.6rem + 7vw, 11.5rem); letter-spacing: -0.035em;">
          <span class="block">{homeCover.titleLine1} <span class="font-serif italic font-light tracking-tighter" style="font-weight:300; font-size: 0.55em; vertical-align: 0.34em; letter-spacing: -0.04em;">{homeCover.titleSmall}</span></span>
          <span class="block italic font-serif font-light tracking-tighter" style="font-weight:300;">{homeCover.titleLine2}</span>
        </h1>
      </div>

      <div class="flex-1 min-h-[2rem]"></div>

      <div class="grid grid-cols-12 gap-6 lg:gap-10 items-end anim-fade-up" style="animation-delay:280ms;">

        <div class="col-span-12 lg:col-span-7">
          <p class="font-serif italic leading-tight text-bone-pale mb-5 max-w-xl" style="font-size: clamp(1.05rem, 0.95rem + 0.5vw, 1.4rem); color: #F7EFD8;">
            {homeCover.tagline}
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={coverPrimary.href} rel={coverPrimary.rel} class="btn-ink" style="background: #F2EAD8; color: #1F1E1B; border-color: #F2EAD8;">{homeCover.primaryCtaLabel}</a>
            <a href={coverSecondary.href} rel={coverSecondary.rel} class="btn-line" style="border-color: rgba(242,234,216,0.85); color: #F7EFD8;">{homeCover.secondaryCtaLabel}</a>
          </div>
        </div>

        <aside class="hidden lg:block lg:col-span-5 lg:pl-6 lg:border-l border-bone-pale/40">
          <p class="block mb-3 font-bold text-[10px] font-mono uppercase tracking-[0.22em]" style="color:#E8B58A;">★ In this issue —</p>
          <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5 text-[10px] font-mono uppercase tracking-[0.16em]">
            {jumpNav.map((j) => (
              <li><a href={j.href} class="no-underline hover:text-clay group inline-flex items-center gap-1.5 transition-colors" style="color: rgba(247,239,216,0.95); text-decoration-color: rgba(232,181,138,0.6);"><span style="color:#E8B58A;">·</span> <span class="group-hover:translate-x-0.5 transition-transform">{j.label}</span></a></li>
            ))}
          </ul>
        </aside>
      </div>

      <div class="mt-8 pt-3 border-t border-bone-pale/40 grid grid-cols-12 gap-3 caption" style="color: rgba(247,239,216,0.85);">
        <span class="col-span-4 lg:col-span-3"><span style="color:#E8B58A;">●</span> {homeCover.captionLabel}</span>
        <span class="col-span-4 lg:col-span-6 text-center hidden sm:block">{homeCover.captionLocation}</span>
        <span class="col-span-4 lg:col-span-3 text-right opacity-75">{homeCover.captionCredit}</span>
      </div>
    </div>

    <style>
      .duotone-cover img { filter: contrast(1.05) saturate(0.85) sepia(0.10) brightness(0.78); }
    </style>
  </Spread>

  {/* ====================================================== */}
  {/* SPREAD 02 — THE VESSEL (What SPIRIT is)                 */}
  {/* ====================================================== */}
  {spreads?.vessel && vesselPrimary && vesselSecondary && (
    <Spread folio="02" section={spreads.vessel.sectionLabel} bg="bone-pale" class="vessel-spread border-y-2 border-ink" id="vessel">
      <div class="px-5 lg:px-10 pt-12 lg:pt-20 pb-16 lg:pb-24">

        <div class="grid grid-cols-3 lg:grid-cols-6 gap-2 lg:gap-3 mb-10 lg:mb-14">
          {[2, 5, 7, 8, 9, 12].map((n, i) => (
            <div class="contact-thumb relative aspect-[4/3] photo">
              <img src={basePath(`images/community/gathering-${String(n).padStart(2,'0')}.jpg`)} alt="" class="w-full h-full object-cover" loading="lazy" />
              <span class="absolute bottom-1 left-1.5 caption text-bone-pale/95 text-[8px] tracking-[0.18em]">P. {String(i+1).padStart(2,'0')}</span>
            </div>
          ))}
        </div>

        <div class="rule-triple mb-8"></div>

        <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start mb-12">
          <div class="col-span-12 lg:col-span-8">
            <div class="flex items-baseline gap-5 mb-3 flex-wrap">
              <span class="folio-num text-5xl lg:text-6xl text-clay-deep">02</span>
              <p class="eyebrow">{spreads.vessel.eyebrow}</p>
            </div>
            <h2 class="display-l text-ink break-words leading-[0.95]">
              {spreads.vessel.heading} <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{spreads.vessel.italicHeading}</span>{spreads.vessel.headingTail && (<Fragment>{spreads.vessel.headingTail}</Fragment>)}
            </h2>
          </div>

          <aside class="col-span-12 lg:col-span-4">
            <div class="diagram-box border-2 border-ink p-4 bg-bone relative">
              <p class="caption text-clay-deep mb-3">{spreads.vessel.diagramCaption}</p>
              <svg viewBox="0 0 240 150" class="w-full" aria-hidden="true">
                <text x="120" y="22" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" font-weight="700" fill="#7E4226" letter-spacing="2">FEEDS &amp; PROTECTS</text>
                <path d="M 50 30 L 50 36 L 190 36 L 190 30" fill="none" stroke="#B8704D" stroke-width="1.2"/>
                <path d="M 116 36 L 120 42 L 124 36" fill="#B8704D"/>

                <rect x="10" y="60" width="90" height="74" fill="none" stroke="#1F1E1B" stroke-width="1.6"/>
                <text x="55" y="86" text-anchor="middle" font-family="Bricolage Grotesque Variable, sans-serif" font-size="13" font-weight="700" fill="#1F1E1B">SPIRIT</text>
                <text x="55" y="102" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4A4A45">501(c)(3)</text>
                <text x="55" y="116" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="#4A4A45">the scaffold</text>

                <circle cx="180" cy="97" r="40" fill="none" stroke="#5C7E8A" stroke-width="1.6"/>
                <text x="180" y="94" text-anchor="middle" font-family="Bricolage Grotesque Variable, sans-serif" font-size="11" font-weight="700" fill="#1F1E1B">COMMONS</text>
                <text x="180" y="108" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6.5" fill="#4A4A45">member-governed</text>

                <text x="10" y="148" font-family="JetBrains Mono, monospace" font-size="6.5" fill="#4A4A45">↳ does not control · does not enclose</text>
              </svg>
            </div>
          </aside>
        </div>

        <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start">

          <div class="col-span-12 lg:col-span-8">
            <div class="body-cols-3 text-body text-ink leading-snug vessel-body">
              <Fragment set:html={injectTermTooltips(mdToHtml(spreads.vessel.body), ['bioregion', 'commons'])} />
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href={vesselPrimary.href} rel={vesselPrimary.rel} class="btn-line">{spreads.vessel.primaryCtaLabel}</a>
              <a href={vesselSecondary.href} rel={vesselSecondary.rel} class="btn-line">{spreads.vessel.secondaryCtaLabel}</a>
            </div>
          </div>

          <aside class="col-span-12 lg:col-span-4 space-y-6 lg:border-l border-ink lg:pl-6">
            <div>
              <p class="sticker sticker-clay inline-block mb-3">{spreads.vessel.editorsNoteTitle}</p>
              <p class="text-body text-shadow leading-snug">
                <Fragment set:html={mdToInline(spreads.vessel.editorsNoteBody)} />
              </p>
            </div>

            <div class="rule"></div>

            <div>
              <p class="sticker sticker-clay inline-block mb-3">{spreads.vessel.languageNoteTitle}</p>
              <p class="font-serif italic text-body-lg leading-snug text-ink">
                "<Fragment set:html={mdToInline(spreads.vessel.languageNoteQuote)} />"
              </p>
              <p class="caption mt-2">{spreads.vessel.languageNoteAttribution}</p>
            </div>
          </aside>
        </div>
      </div>
    </Spread>
  )}

  {/* ====================================================== */}
  {/* SPREAD 03 — PROGRAMS (Easy ways to get involved)        */}
  {/* ====================================================== */}
  {spreads?.programsTeaser && programsTeaserCta && (
    <Spread folio="03" section={spreads.programsTeaser.sectionLabel} bg="bone-deep" class="programs-spread border-y-2 border-ink" id="programs">
      <div class="px-5 lg:px-10 pt-14 lg:pt-20 pb-16 lg:pb-24">

        <div class="grid grid-cols-12 gap-6 mb-10 lg:mb-14 items-baseline">
          <div class="col-span-12 lg:col-span-7">
            <p class="eyebrow eyebrow-creek mb-3">{spreads.programsTeaser.eyebrow}</p>
            <h2 class="display-l text-ink break-words leading-[1.05]">
              {spreads.programsTeaser.heading} <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{spreads.programsTeaser.italicHeading}</span>
            </h2>
          </div>
          <div class="col-span-12 lg:col-span-5 lg:pl-8 lg:border-l border-ink">
            <p class="text-body text-shadow leading-snug mb-2 programs-intro">
              <Fragment set:html={mdToInline(spreads.programsTeaser.intro)} />
            </p>
            <p class="caption text-shadow">{spreads.programsTeaser.caption}</p>
          </div>
        </div>

        <div class="rule-bold mb-10"></div>

        <div class="grid grid-cols-1 md:grid-cols-3 md:[grid-template-rows:auto_auto_auto_auto_1fr_auto] gap-x-6 lg:gap-x-10 gap-y-12 md:gap-y-3">
          {programs.slice(0, 3).map((p, i) => {
            const photoNum = teaserPhotos[i];
            const tone = teaserTones[i];
            return (
              <article class="program-cat md:grid md:[grid-template-rows:subgrid] md:row-span-6 flex flex-col gap-y-3 md:gap-y-0">
                <div class="aspect-[4/5] photo duotone-cover md:mb-2">
                  <img src={basePath(`images/community/gathering-${photoNum}.jpg`)} alt="" class="ken-burns" loading="lazy" />
                </div>
                <div class="flex items-baseline justify-between gap-2">
                  <span class={`folio-num text-3xl ${pillarTone[tone].text} leading-none`}>{String(i + 1).padStart(2, '0')}</span>
                  <span class="sticker sticker-bone">{p.data.abbrev}</span>
                </div>
                <p class={`eyebrow ${pillarTone[tone].text}`}>{p.data.pillarLabel}</p>
                <h3 class="font-display font-bold text-h2 text-ink leading-[1.05] break-words md:min-h-[2.4em]">{p.data.title}</h3>
                <p class="text-body text-shadow leading-snug self-start mt-3 pb-6 lg:pb-8">{p.data.shortDescription}</p>
                <div class="flex items-baseline justify-between gap-2 caption pt-3 border-t border-rule self-end w-full">
                  <span class={pillarTone[tone].text}>● {p.data.status}</span>
                  <a href={`${BASE}programs/`} class={`${pillarTone[tone].text} no-underline hover:underline`}>get on list →</a>
                </div>
              </article>
            );
          })}
        </div>

        <div class="mt-12 flex items-baseline justify-between gap-3 pt-6 border-t-2 border-ink">
          <p class="caption">{spreads.programsTeaser.footnote}</p>
          <a href={programsTeaserCta.href} rel={programsTeaserCta.rel} class="btn-ink">{spreads.programsTeaser.ctaLabel}</a>
        </div>
      </div>
    </Spread>
  )}

  {/* ====================================================== */}
  {/* SPREAD 04 — FOUR PILLARS                                */}
  {/* ====================================================== */}
  {spreads?.pillars && (
    <Spread folio="04" section={spreads.pillars.sectionLabel} bg="bone" class="pillars-spread" id="pillars">
      <div class="px-5 lg:px-10 pt-16 lg:pt-24 pb-20 lg:pb-32 relative">

        <div class="grid grid-cols-12 gap-6 lg:gap-10 mb-10 lg:mb-12 items-end">
          <div class="col-span-12 lg:col-span-7">
            <p class="eyebrow mb-3">{spreads.pillars.eyebrow}</p>
            <h2 class="display-l text-ink break-words leading-[0.92]">
              {spreads.pillars.heading} <span class="italic font-serif font-light" style="font-weight:300;">{spreads.pillars.italicHeading}</span>
            </h2>
          </div>
          <div class="col-span-12 lg:col-span-5 lg:pl-8 lg:border-l border-ink">
            <p class="text-body text-shadow leading-snug">
              <Fragment set:html={mdToInline(spreads.pillars.intro)} />
            </p>
            <p class="caption mt-3 text-shadow">{spreads.pillars.caption}</p>
          </div>
        </div>

        <div class="rule-double mb-12"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 lg:gap-x-16 gap-y-12 lg:gap-y-16 relative">
          {spreads.pillars.items.map((item, i) => {
            const photoMap = ['09', '07', '06', '04'];
            return (
              <article class="pillar-cat group flex flex-col">
                <p class={`eyebrow ${pillarTone[item.color].text} mb-2`}>{item.pillar}</p>
                <div class="flex items-baseline gap-3 mb-5 flex-wrap">
                  <span class={`folio-num text-3xl lg:text-4xl ${pillarTone[item.color].text} leading-none`}>{item.number}</span>
                  <h3 class="display-m text-ink leading-[0.92]">{item.title}</h3>
                </div>
                <div class={`aspect-[5/3] mb-4 photo ${pillarTone[item.color].photo}`}>
                  <img src={basePath(`images/community/gathering-${photoMap[i]}.jpg`)} alt={item.title} loading="lazy" />
                </div>
                <p class={`caption ${pillarTone[item.color].text} mb-3`}>{item.photoCaption}</p>
                <p class="text-body text-ink leading-snug mb-4 flex-1 pillar-body">
                  <Fragment set:html={mdToInline(item.body)} />
                </p>
                <div class="flex items-baseline gap-3 caption mt-auto pt-3 border-t border-rule">
                  <span class={pillarTone[item.color].text}>★ outcome:</span>
                  <span>{item.outcome}</span>
                </div>
              </article>
            );
          })}

          <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 -translate-x-1/2 w-px bg-ink/40 pointer-events-none"></div>
        </div>

        <div class="rule-double mt-16"></div>
        <p class="caption text-shadow mt-3 text-right">{spreads.pillars.footnote}</p>
      </div>
    </Spread>
  )}

  {/* ====================================================== */}
  {/* SPREAD 05 — ETHICS TEASER (short, links to mission)    */}
  {/* ====================================================== */}
  {spreads?.ethicsTeaser && ethicsTeaserCta && (
    <Spread folio="05" section={spreads.ethicsTeaser.sectionLabel} bg="bone-deep" class="border-y border-ink" id="ethics">
      <div class="px-5 lg:px-12 py-16 lg:py-24">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">
          <div class="col-span-12 lg:col-span-5">
            <span class="folio-num text-7xl text-clay-deep block leading-none">05</span>
            <p class="eyebrow text-clay-deep mt-4 mb-3">{spreads.ethicsTeaser.eyebrow}</p>
            <h2 class="display-l text-ink leading-[0.95] break-words">
              {spreads.ethicsTeaser.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.ethicsTeaser.italicHeading}</span>{spreads.ethicsTeaser.headingTail && (<Fragment>{spreads.ethicsTeaser.headingTail}</Fragment>)}
            </h2>
          </div>
          <div class="col-span-12 lg:col-span-7 lg:pl-8 lg:border-l border-ink">
            <p class="text-body-lg text-ink leading-snug max-w-2xl mb-8 ethics-teaser-body">
              <Fragment set:html={mdToInline(spreads.ethicsTeaser.body)} />
            </p>
            <a href={ethicsTeaserCta.href} rel={ethicsTeaserCta.rel} class="btn-line">{spreads.ethicsTeaser.ctaLabel}</a>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* ====================================================== */}
  {/* SPREAD 06 — THE COMMONS (compact card link-out)        */}
  {/* ====================================================== */}
  {spreads?.commonsTeaser && commonsTeaserPrimary && commonsTeaserSecondary && (
    <Spread folio="06" section={spreads.commonsTeaser.sectionLabel} bg="bone" class="commons-card-spread" id="commons">
      <div class="px-5 lg:px-12 py-16 lg:py-24">
        <div class="grid grid-cols-12 gap-6 lg:gap-10 items-stretch">

          {/* LEFT — compact image */}
          <div class="col-span-12 lg:col-span-5 relative bg-creek-deep min-h-[280px] lg:min-h-[360px] border border-ink">
            <div class="absolute inset-0 photo duotone-creek">
              <img src={basePath(spreads.commonsTeaser.imageSrc ?? 'images/community/gathering-08.jpg')} alt="Water pooled in a red rock crevice." class="w-full h-full object-cover ken-burns" loading="lazy" />
            </div>
            {spreads.commonsTeaser.imageCaption && (
              <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-creek-deep/85 to-transparent">
                <span class="caption text-bone-pale/90">{spreads.commonsTeaser.imageCaption}</span>
              </div>
            )}
          </div>

          {/* RIGHT — heading + ~50 word body + 2 CTAs */}
          <div class="col-span-12 lg:col-span-7 lg:pl-2 flex flex-col justify-center">
            <div class="flex items-baseline gap-4 mb-4">
              <span class="folio-num text-5xl text-creek-deep">06</span>
              <p class="eyebrow eyebrow-creek">{spreads.commonsTeaser.eyebrow}</p>
            </div>
            <h2 class="display-m text-ink mb-5 leading-[0.95] break-words">
              {spreads.commonsTeaser.heading} <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{spreads.commonsTeaser.italicHeading}</span>{spreads.commonsTeaser.headingTail && (<Fragment>{spreads.commonsTeaser.headingTail}</Fragment>)}
            </h2>
            <div class="text-body text-ink leading-snug max-w-2xl mb-6 commons-card-body">
              <Fragment set:html={injectTermTooltips(mdToInline(spreads.commonsTeaser.body), ['bioregion', 'commons'])} />
            </div>
            <div class="flex flex-wrap gap-3">
              <a href={commonsTeaserPrimary.href} rel={commonsTeaserPrimary.rel} class="btn-ink">{spreads.commonsTeaser.primaryCtaLabel}</a>
              <a href={commonsTeaserSecondary.href} rel={commonsTeaserSecondary.rel} class="btn-line">{spreads.commonsTeaser.secondaryCtaLabel}</a>
            </div>
          </div>

        </div>
      </div>
    </Spread>
  )}

  {/* ====================================================== */}
  {/* SPREAD 07 — HOME GLOSSARY (Words section)              */}
  {/* ====================================================== */}
  {spreads?.homeGlossary && (
    <Spread folio="07" section={spreads.homeGlossary.sectionLabel} bg="bone-pale" class="border-y border-ink" id="glossary">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">
          <div class="col-span-12 lg:col-span-4">
            <span class="folio-num text-7xl text-creek-deep block leading-none">07</span>
            <p class="eyebrow eyebrow-creek mt-4 mb-3">{spreads.homeGlossary.eyebrow}</p>
            <h2 class="display-l text-ink leading-[0.95] mb-6 break-words">
              {spreads.homeGlossary.heading} <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{spreads.homeGlossary.italicHeading}</span>
            </h2>
            <p class="text-body text-shadow leading-snug max-w-md mb-6">
              {spreads.homeGlossary.intro}
            </p>
            {spreads.homeGlossary.ctaLabel && spreads.homeGlossary.ctaHref && (
              <a href={basePath(spreads.homeGlossary.ctaHref)} class="no-underline font-mono text-xs uppercase tracking-[0.18em] font-bold text-creek-deep hover:text-clay-deep">
                {spreads.homeGlossary.ctaLabel}
              </a>
            )}
          </div>
          <div class="col-span-12 lg:col-span-8">
            <div class="grid sm:grid-cols-2 gap-x-8 gap-y-8">
              {spreads.homeGlossary.terms.map((t) => (
                <article class="border-t border-ink pt-4">
                  <span class={`folio-num text-2xl text-${t.color}-deep block mb-1`}>{t.number}</span>
                  <p class={`eyebrow text-${t.color}-deep mb-2`}>{t.term}</p>
                  <p class="text-body text-shadow leading-snug">{t.body}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* ====================================================== */}
  {/* SPREAD 08 — DONATE / BACK COVER                         */}
  {/* ====================================================== */}
  {spreads?.funding && fundingPrimary && fundingSecondary && (
    <Spread folio="08" section={spreads.funding.sectionLabel} bg="image" minHeight="100svh" class="donate-spread overflow-hidden" id="funding">

      <div class="absolute inset-0 photo" aria-hidden="true">
        <img src={basePath('images/community/gathering-02.jpg')} alt="" class="w-full h-full object-cover ken-burns" loading="lazy" style="filter: contrast(1.05) brightness(0.5) saturate(0.8);" />
      </div>
      <div class="absolute inset-0 pointer-events-none"
           style="background:
             radial-gradient(80% 60% at 30% 50%, rgba(126,66,38,0.35) 0%, transparent 70%),
             linear-gradient(180deg, rgba(31,30,27,0.35) 0%, rgba(31,30,27,0.65) 100%);"></div>

      <div class="relative px-5 lg:px-12 py-16 lg:py-24 on-dark">

        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-end min-h-[80svh]">

          <div class="col-span-12 lg:col-span-7">
            <p class="eyebrow mb-4" style="color:#E8B58A;">{spreads.funding.eyebrow}</p>
            <h2 class="display-l leading-[1.0]" style="color: #F7EFD8;">
              {spreads.funding.heading} <span class="italic font-serif font-light" style="font-weight:300; color:#E8B58A;">{spreads.funding.italicHeading}</span>{spreads.funding.headingTail && (<Fragment>{spreads.funding.headingTail}</Fragment>)}
            </h2>
            <p class="mt-8 text-body-lg leading-snug max-w-2xl text-bone-pale/90 funding-body">
              <Fragment set:html={mdToInline(spreads.funding.body)} />
            </p>
            <div class="mt-10 flex flex-wrap gap-3">
              <a href={fundingPrimary.href} rel={fundingPrimary.rel} class="btn-ink" style="background: #F2EAD8; color: #1F1E1B; border-color: #F2EAD8;">{spreads.funding.primaryCtaLabel}</a>
              <a href={fundingSecondary.href} rel={fundingSecondary.rel} class="btn-line" style="border-color: rgba(242,234,216,0.7); color: #F2EAD8;">{spreads.funding.secondaryCtaLabel}</a>
            </div>
          </div>

          <aside class="col-span-12 lg:col-span-5">
            <div class="border-2 border-bone-pale/70 p-5 lg:p-6 backdrop-blur-sm" style="background: rgba(31,30,27,0.40);">
              <p class="caption mb-4" style="color:#E8B58A;">{spreads.funding.cascadeTitle}</p>
              <ol class="space-y-5 text-bone-pale/95">
                {spreads.funding.cascadeTiers.map((tier, i) => (
                  <li class={`flex gap-4 items-start ${i < spreads!.funding!.cascadeTiers.length - 1 ? 'pb-4 border-b border-bone-pale/30' : ''}`}>
                    <span class="font-display font-extrabold text-4xl" style="color:#E8B58A;">{tier.number}</span>
                    <div>
                      <p class="font-display font-bold text-h3 leading-tight">{tier.title}</p>
                      <p class="caption opacity-80 mt-1">{tier.caption}</p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
            <p class="mt-3 caption text-bone-pale/70 text-right">
              {spreads.funding.cascadeCaption}
            </p>
          </aside>
        </div>

        <div class="mt-12 pt-6 border-t border-bone-pale/30 grid grid-cols-12 gap-3 caption text-bone-pale/70">
          <span class="col-span-3">{spreads.funding.footerLeft}</span>
          <span class="col-span-6 text-center hidden sm:block">{spreads.funding.footerCenter}</span>
          <span class="col-span-3 text-right">{spreads.funding.footerRight}</span>
        </div>
      </div>
    </Spread>
  )}

</Base>

<style>
  main { display: block; }
  .vessel-body :global(p) { margin-top: 0.75rem; }
  .vessel-body :global(p:first-child) { margin-top: 0; }
  .commons-card-body :global(p) { margin-top: 0.6rem; }
  .commons-card-body :global(p:first-child) { margin-top: 0; }
  .ethics-teaser-body :global(p) { margin-top: 0.5rem; }
  .ethics-teaser-body :global(p:first-child) { margin-top: 0; }
  .pillar-body :global(p) { margin: 0; }
  .programs-intro :global(a) { color: var(--color-creek-deep); text-decoration: underline; }
</style>
