---
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import { getEntry } from 'astro:content';
import { basePath, resolveLink } from '../lib/paths';
import { mdToInline } from '../lib/markdown';

const entry = await getEntry('pages', 'connect');
if (!entry) throw new Error('Missing src/content/pages/connect.md');
const { seo, cover, spreads } = entry.data;

// Connect's card eyebrow classes differ from mission's (eyebrow-clay vs text-clay-deep)
// — preserve original visual identity per page.
const cardClasses = {
  clay: { folio: 'text-clay-deep', eyebrow: 'eyebrow eyebrow-clay', link: 'text-clay-deep' },
  creek: { folio: 'text-creek-deep', eyebrow: 'eyebrow eyebrow-creek', link: 'text-creek-deep' },
  sage: { folio: 'text-sage-deep', eyebrow: 'eyebrow eyebrow-sage', link: 'text-sage-deep' },
  grass: { folio: 'text-grass-deep', eyebrow: 'eyebrow text-grass-deep', link: 'text-grass-deep' },
} as const;

const newsletterCta = spreads?.newsletter ? resolveLink(spreads.newsletter.ctaHref) : null;
---

<Base title={seo.title} description={seo.description}>

  <PageCover
    folio="07"
    sectionLabel="Connect"
    eyebrow={cover.eyebrow}
    title={cover.title}
    italicTitle={cover.italicTitle}
    subtitle={cover.subtitle}
    imageSrc={basePath(cover.imageSrc)}
    imageAlt={cover.imageAlt}
    plate=""
    plateCaption={cover.plateCaption}
    treatment={cover.treatment}
    brightness={cover.brightness}
  />

  {/* FOUR WAYS */}
  {spreads?.fourWays && (
    <Spread folio="07.1" section={spreads.fourWays.sectionLabel} bg="bone">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start mb-10">
          <div class="col-span-12 lg:col-span-4 lg:sticky lg:top-8 self-start space-y-5">
            <span class="folio-num text-7xl text-clay-deep">07.i</span>
            <Marginalia number="01">
              <Fragment set:html={mdToInline(spreads.fourWays.marginaliaPrimary)} />
            </Marginalia>
            <Marginalia>
              <Fragment set:html={mdToInline(spreads.fourWays.marginaliaSecondary)} />
            </Marginalia>
          </div>

          <div class="col-span-12 lg:col-span-8">
            <div class="rule-double mb-6"></div>
            <p class="eyebrow mb-3">{spreads.fourWays.eyebrow}</p>
            <h2 class="display-l text-ink break-words leading-[0.95] mb-6">
              {spreads.fourWays.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.fourWays.italicHeading}</span>
            </h2>
            <p class="text-body-lg text-shadow italic font-serif leading-snug mb-10 max-w-2xl">
              {spreads.fourWays.subheading}
            </p>

            <div class="grid sm:grid-cols-2 gap-6">
              {spreads.fourWays.cards.map((c) => {
                const link = resolveLink(c.ctaHref);
                const classes = cardClasses[c.color];
                return (
                  <article class="paper p-6">
                    <span class={`folio-num text-3xl ${classes.folio} mb-1 block`}>{c.number}</span>
                    <p class={`${classes.eyebrow} mb-2`}>{c.eyebrow}</p>
                    <h3 class="font-display font-bold text-h3 text-ink leading-tight mb-3">{c.title}</h3>
                    <p class="text-body text-shadow leading-relaxed mb-4">
                      {c.body}
                    </p>
                    <a
                      href={link.href}
                      rel={link.rel}
                      class:list={[
                        'no-underline font-mono text-xs uppercase tracking-[0.18em] font-bold hover:text-ink',
                        classes.link,
                        link.isMailto && 'break-all',
                      ]}
                    >
                      {c.ctaLabel}
                    </a>
                  </article>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* NEWSLETTER — link out to dashboard subscribe */}
  {spreads?.newsletter && newsletterCta && (
    <Spread folio="07.2" section={spreads.newsletter.sectionLabel} bg="bone-pale" class="border-y border-ink">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-center">

          <div class="col-span-12 lg:col-span-6">
            <span class="folio-num text-6xl text-creek-deep mb-4 block">07.ii</span>
            <p class="eyebrow eyebrow-creek mb-3">{spreads.newsletter.eyebrow}</p>
            <h2 class="display-m text-ink leading-[1.0] mb-5">
              {spreads.newsletter.heading} <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{spreads.newsletter.italicHeading}</span>
            </h2>
            <p class="text-body-lg text-shadow leading-snug max-w-lg">
              {spreads.newsletter.body}
            </p>
          </div>

          <div class="col-span-12 lg:col-span-6">
            <div class="paper p-8 lg:p-10 flex flex-col items-start gap-5">
              <p class="eyebrow eyebrow-clay">{spreads.newsletter.eyebrow}</p>
              <p class="text-body text-shadow leading-snug">
                Subscriptions are handled on our community dashboard — events,
                program openings, and the slow newsletter, all in one place.
              </p>
              <a
                href={newsletterCta.href}
                rel={newsletterCta.rel}
                target="_blank"
                class="btn-ink w-full justify-center !py-3"
              >
                {spreads.newsletter.ctaLabel}
              </a>
              <p class="caption text-shadow">
                {spreads.newsletter.footnote}
              </p>
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

</Base>

<style>
  .py-section { padding-block: var(--spacing-section); }
</style>
