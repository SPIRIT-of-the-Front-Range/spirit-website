---
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import Plate from '../components/editorial/Plate.astro';
import PullQuote from '../components/editorial/PullQuote.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import PillarWeave from '../components/interactive/PillarWeave.astro';
import { getEntry } from 'astro:content';
import { basePath } from '../lib/paths';
import { mdToHtml, mdToInline } from '../lib/markdown';

const entry = await getEntry('pages', 'mission');
if (!entry) throw new Error('Missing src/content/pages/mission.md');
const { seo, cover, spreads, pullQuote, closing } = entry.data;

// Tailwind v4 needs literal class strings to discover them at build time —
// keep the per-color class map fully expanded.
const cardClasses = {
  clay: { folio: 'text-clay-deep', eyebrow: 'eyebrow text-clay-deep' },
  creek: { folio: 'text-creek-deep', eyebrow: 'eyebrow eyebrow-creek' },
  sage: { folio: 'text-sage-deep', eyebrow: 'eyebrow eyebrow-sage' },
  grass: { folio: 'text-grass-deep', eyebrow: 'eyebrow text-grass-deep' },
} as const;
---

<Base title={seo.title} description={seo.description}>

  <PageCover
    folio="02"
    sectionLabel="Mission"
    eyebrow={cover.eyebrow}
    title={cover.title}
    italicTitle={cover.italicTitle}
    subtitle={cover.subtitle}
    imageSrc={basePath(cover.imageSrc)}
    imageAlt={cover.imageAlt}
    plate=""
    plateCaption={cover.plateCaption}
    treatment={cover.treatment}
    brightness={cover.brightness}
  />

  {/* SPREAD — VISION */}
  {spreads?.vision && (
    <Spread folio="02.1" section={spreads.vision.sectionLabel} bg="bone">
      <div class="px-5 lg:px-12 pt-section pb-16">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

          <div class="col-span-12 lg:col-span-3 lg:sticky lg:top-8 self-start space-y-5">
            <span class="folio-num text-7xl text-clay-deep">02.i</span>
            <Marginalia number="01">
              <Fragment set:html={mdToInline(spreads.vision.marginalia)} />
            </Marginalia>
          </div>

          <div class="col-span-12 lg:col-span-9">
            <div class="rule-double mb-6"></div>
            <p class="eyebrow mb-3">{spreads.vision.eyebrow}</p>
            <h2 class="display-l lg:display-xl text-ink leading-[0.95] lg:leading-[0.92] break-words mb-10 max-w-4xl">
              {spreads.vision.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.vision.italicHeading}</span>
            </h2>

            <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start">
              <div class="col-span-12 lg:col-span-7 text-body-lg text-ink leading-snug space-y-4 dropcap">
                <Fragment set:html={mdToHtml(spreads.vision.body)} />
              </div>
              <div class="col-span-12 lg:col-span-5">
                <Plate
                  src={basePath(spreads.vision.image)}
                  alt={spreads.vision.imageAlt}
                  treatment="warm"
                  label="●"
                  caption={spreads.vision.imageCaption}
                  ratio="3/4"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* SPREAD — MISSION (sage tint) */}
  {spreads?.mission && (
    <Spread folio="02.2" section={spreads.mission.sectionLabel} bg="bone-pale" class="border-y border-ink">
      <div class="px-5 lg:px-12 pt-section pb-16">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

          <div class="col-span-12 lg:col-span-9 lg:order-2">
            <div class="rule-double mb-6"></div>
            <p class="eyebrow eyebrow-sage mb-3">{spreads.mission.eyebrow}</p>
            <h2 class="display-l lg:display-xl text-ink leading-[0.95] lg:leading-[0.92] break-words mb-10 max-w-5xl">
              {spreads.mission.heading} <span class="italic font-serif font-light text-sage-deep" style="font-weight:300;">{spreads.mission.italicHeading}</span>
            </h2>

            <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start">
              <div class="col-span-12 lg:col-span-7 text-body-lg text-ink leading-snug space-y-4">
                <Fragment set:html={mdToHtml(spreads.mission.body)} />
                {spreads.mission.italicNote && (
                  <p class="font-serif italic text-sage-deep">{spreads.mission.italicNote}</p>
                )}
              </div>
              <div class="col-span-12 lg:col-span-5">
                <Plate
                  src={basePath(spreads.mission.image)}
                  alt={spreads.mission.imageAlt}
                  treatment="warm"
                  label="●"
                  caption={spreads.mission.imageCaption}
                  ratio="3/4"
                />
              </div>
            </div>
          </div>

          <div class="col-span-12 lg:col-span-3 lg:order-1 lg:sticky lg:top-8 self-start space-y-5">
            <span class="folio-num text-7xl text-sage-deep">02.ii</span>
            <Marginalia number="02">
              <Fragment set:html={mdToInline(spreads.mission.marginalia)} />
            </Marginalia>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* PULL QUOTE */}
  {pullQuote && (
    <div class="bg-bone py-section">
      <div class="container-narrow">
        <PullQuote attribution={pullQuote.attribution}>
          {pullQuote.text}
        </PullQuote>
      </div>
    </div>
  )}

  {/* SPREAD — STRATEGY */}
  {spreads?.strategy && (
    <Spread folio="02.3" section={spreads.strategy.sectionLabel} bg="bone">
      <div class="px-5 lg:px-12 pt-section pb-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start mb-12">
          <div class="col-span-12 lg:col-span-3 lg:sticky lg:top-8 self-start space-y-5">
            <span class="folio-num text-5xl lg:text-7xl text-creek-deep block leading-none whitespace-nowrap">02.iii</span>
            <Marginalia number="03">
              <Fragment set:html={mdToInline(spreads.strategy.marginalia)} />
            </Marginalia>
          </div>
          <div class="col-span-12 lg:col-span-9">
            <div class="rule-double mb-6"></div>
            <p class="eyebrow eyebrow-creek mb-3">{spreads.strategy.eyebrow}</p>
            <h2 class="display-l lg:display-xl text-ink leading-[0.95] lg:leading-[0.92] break-words mb-8 max-w-5xl">
              {spreads.strategy.heading} <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{spreads.strategy.italicHeading}</span>
            </h2>
            <p class="text-body-lg text-ink leading-snug max-w-3xl mb-10">
              {spreads.strategy.intro}
            </p>

            <div class="my-12 max-w-2xl">
              <PillarWeave />
              <p class="caption mt-3">{spreads.strategy.weaveCaption}</p>
            </div>

            <div class="grid sm:grid-cols-2 gap-x-8 gap-y-10 mt-12 pt-8 border-t border-rule">
              {spreads.strategy.pillars.map((p) => (
                <article>
                  <span class={`folio-num text-3xl ${cardClasses[p.color].folio} mb-2 block`}>{p.number}</span>
                  <p class={`${cardClasses[p.color].eyebrow} mb-2`}>{p.title}</p>
                  <p class="text-body text-shadow leading-snug">
                    {p.body}
                  </p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* THREE COMMITMENTS triptych */}
  {spreads?.commitments && (
    <Spread folio="02.4" section={spreads.commitments.sectionLabel} bg="bone-deep" class="border-y border-ink">
      <div class="px-5 lg:px-12 py-section">
        <div class="rule-bold mb-6"></div>
        <p class="eyebrow mb-3">{spreads.commitments.eyebrow}</p>
        <h2 class="display-l text-ink mb-12 max-w-3xl leading-[1.0]">
          {spreads.commitments.heading}
        </h2>

        <div class="grid md:grid-cols-3 gap-x-10 gap-y-12">
          {spreads.commitments.items.map((item) => (
            <article>
              <span class={`folio-num text-5xl ${cardClasses[item.color].folio} mb-3 block`}>{item.number}</span>
              <h3 class="font-display font-bold text-h2 text-ink mb-3 leading-tight" set:html={item.title}></h3>
              <p class="text-body text-shadow leading-snug">
                {item.body}
              </p>
            </article>
          ))}
        </div>
      </div>
    </Spread>
  )}

  {/* CLOSING */}
  {closing && (
    <section class="py-section text-center container-edit">
      <p class="eyebrow mb-4">{closing.eyebrow}</p>
      <p class="font-serif italic text-h1 text-ink max-w-3xl mx-auto leading-snug mb-8">
        {closing.text}
      </p>
      <a href={basePath(closing.ctaHref)} class="btn-ink">{closing.ctaLabel}</a>
    </section>
  )}

</Base>

<style>
  .py-section { padding-block: var(--spacing-section); }
  .pt-section { padding-top: var(--spacing-section); }
</style>
