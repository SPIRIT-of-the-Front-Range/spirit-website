---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import Plate from '../components/editorial/Plate.astro';
import PullQuote from '../components/editorial/PullQuote.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import PillarWeave from '../components/interactive/PillarWeave.astro';
import { md, mdInline } from '../lib/md';

const BASE = import.meta.env.BASE_URL;
const entry = await getEntry('pages', 'mission');
if (!entry) throw new Error('Missing content/pages/mission.md');
const d = entry.data as any;

const toneTextClass = {
  clay: 'text-clay-deep',
  creek: 'text-creek-deep',
  sage: 'text-sage-deep',
  grass: 'text-grass-deep',
} as const;

const toneEyebrowClass = {
  clay: 'text-clay-deep',
  creek: 'eyebrow-creek',
  sage: 'eyebrow-sage',
  grass: 'text-grass-deep',
} as const;
---

<Base title={d.title} description={d.description}>

  <PageCover
    folio={d.cover.folio}
    sectionLabel={d.cover.sectionLabel}
    eyebrow={d.cover.eyebrow}
    title={d.cover.title}
    italicTitle={d.cover.italicTitle}
    subtitle={d.cover.subtitle}
    imageSrc={`${BASE}${d.cover.image}`}
    imageAlt={d.cover.imageAlt}
    plate=""
    plateCaption={d.cover.plateCaption}
    treatment={d.cover.treatment}
    brightness={d.cover.brightness}
  />

  {/* SPREAD — VISION */}
  <Spread folio={d.vision.folio} section="Vision" bg="bone">
    <div class="px-5 lg:px-12 pt-section pb-16">
      <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

        <div class="col-span-12 lg:col-span-3 lg:sticky lg:top-8 self-start space-y-5">
          <span class="folio-num text-7xl text-clay-deep">{d.vision.folioNum}</span>
          <Marginalia number={d.vision.marginaliaNumber}>
            <strong>{d.vision.marginaliaLabel}</strong> {d.vision.marginaliaBody}
          </Marginalia>
        </div>

        <div class="col-span-12 lg:col-span-9">
          <div class="rule-double mb-6"></div>
          <p class="eyebrow mb-3">{d.vision.eyebrow}</p>
          <h2 class="display-l lg:display-xl text-ink leading-[0.95] lg:leading-[0.92] break-words mb-10 max-w-4xl">
            {d.vision.headline} {d.vision.italicHeadline && (
              <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{d.vision.italicHeadline}</span>
            )}
          </h2>

          <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start">
            <div class="col-span-12 lg:col-span-7 text-body-lg text-ink leading-snug space-y-4 dropcap" set:html={md(d.vision.body)}></div>
            <div class="col-span-12 lg:col-span-5">
              <Plate
                src={`${BASE}${d.vision.image}`}
                alt={d.vision.imageAlt}
                treatment="warm"
                label="●"
                caption={d.vision.imageCaption}
                ratio="3/4"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </Spread>

  {/* SPREAD — MISSION (sage tint) */}
  <Spread folio={d.mission.folio} section="Mission" bg="bone-pale" class="border-y border-ink">
    <div class="px-5 lg:px-12 pt-section pb-16">
      <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

        <div class="col-span-12 lg:col-span-9 lg:order-2">
          <div class="rule-double mb-6"></div>
          <p class="eyebrow eyebrow-sage mb-3">{d.mission.eyebrow}</p>
          <h2 class="display-l lg:display-xl text-ink leading-[0.95] lg:leading-[0.92] break-words mb-10 max-w-5xl">
            {d.mission.headline} {d.mission.italicHeadline && (
              <span class="italic font-serif font-light text-sage-deep" style="font-weight:300;">{d.mission.italicHeadline}</span>
            )}
          </h2>

          <div class="grid grid-cols-12 gap-6 lg:gap-10 items-start">
            <div class="col-span-12 lg:col-span-7 text-body-lg text-ink leading-snug space-y-4 mission-body" set:html={md(d.mission.body)}></div>
            <div class="col-span-12 lg:col-span-5">
              <Plate
                src={`${BASE}${d.mission.image}`}
                alt={d.mission.imageAlt}
                treatment="warm"
                label="●"
                caption={d.mission.imageCaption}
                ratio="3/4"
              />
            </div>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-3 lg:order-1 lg:sticky lg:top-8 self-start space-y-5">
          <span class="folio-num text-7xl text-sage-deep">{d.mission.folioNum}</span>
          <Marginalia number={d.mission.marginaliaNumber}>
            <strong>{d.mission.marginaliaLabel}</strong> {d.mission.marginaliaBody}
          </Marginalia>
        </div>
      </div>
    </div>
  </Spread>

  {/* PULL QUOTE */}
  <div class="bg-bone py-section">
    <div class="container-narrow">
      <PullQuote attribution={d.pullQuote.attribution}>
        {d.pullQuote.text}
      </PullQuote>
    </div>
  </div>

  {/* SPREAD — STRATEGY */}
  <Spread folio={d.strategy.folio} section="Strategy" bg="bone">
    <div class="px-5 lg:px-12 pt-section pb-section">
      <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start mb-12">
        <div class="col-span-12 lg:col-span-3 lg:sticky lg:top-8 self-start space-y-5">
          <span class="folio-num text-7xl text-creek-deep">{d.strategy.folioNum}</span>
          <Marginalia number={d.strategy.marginaliaNumber}>
            <strong>{d.strategy.marginaliaLabel}</strong> {d.strategy.marginaliaBody}
          </Marginalia>
        </div>
        <div class="col-span-12 lg:col-span-9">
          <div class="rule-double mb-6"></div>
          <p class="eyebrow eyebrow-creek mb-3">{d.strategy.eyebrow}</p>
          <h2 class="display-l lg:display-xl text-ink leading-[0.95] lg:leading-[0.92] break-words mb-8 max-w-5xl">
            {d.strategy.headline} {d.strategy.italicHeadline && (
              <span class="italic font-serif font-light text-creek-deep" style="font-weight:300;">{d.strategy.italicHeadline}</span>
            )}
          </h2>
          <p class="text-body-lg text-ink leading-snug max-w-3xl mb-10">
            {d.strategy.lead}
          </p>

          <div class="my-12 max-w-2xl">
            <PillarWeave />
            <p class="caption mt-3">{d.strategy.pillarWeaveCaption}</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-10 mt-12 pt-8 border-t border-rule">
            {d.strategy.pillars.map((p: any) => (
              <article>
                <span class={`folio-num text-3xl mb-2 block ${toneTextClass[p.tone as keyof typeof toneTextClass]}`}>{p.number}</span>
                <p class={`eyebrow mb-2 ${toneEyebrowClass[p.tone as keyof typeof toneEyebrowClass]}`}>{p.label}</p>
                <p class="text-body text-shadow leading-snug">{p.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Spread>

  {/* THREE COMMITMENTS triptych */}
  <Spread folio={d.commitments.folio} section="Commitments" bg="bone-deep" class="border-y border-ink">
    <div class="px-5 lg:px-12 py-section">
      <div class="rule-bold mb-6"></div>
      <p class="eyebrow mb-3">{d.commitments.eyebrow}</p>
      <h2 class="display-l text-ink mb-12 max-w-3xl leading-[1.0]">
        {d.commitments.headline}
      </h2>

      <div class="grid md:grid-cols-3 gap-x-10 gap-y-12">
        {d.commitments.items.map((c: any) => (
          <article>
            <span class={`folio-num text-5xl mb-3 block ${toneTextClass[c.tone as keyof typeof toneTextClass]}`}>{c.number}</span>
            <h3 class="font-display font-bold text-h2 text-ink mb-3 leading-tight" set:html={mdInline(c.title)}></h3>
            <p class="text-body text-shadow leading-snug">{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </Spread>

  {/* CLOSING */}
  <section class="py-section text-center container-edit">
    <p class="eyebrow mb-4">{d.closing.eyebrow}</p>
    <p class="font-serif italic text-h1 text-ink max-w-3xl mx-auto leading-snug mb-8">
      {d.closing.text}
    </p>
    <a href={`${BASE}${d.closing.ctaUrl}`} class="btn-ink">{d.closing.ctaLabel}</a>
  </section>

</Base>

<style>
  .py-section { padding-block: var(--spacing-section); }
  .pt-section { padding-top: var(--spacing-section); }
  /* preserve italic emphasis color in the mission body */
  .mission-body em { font-style: italic; color: var(--color-sage-deep); }
  /* honor the last paragraph italic styling */
  .mission-body p:last-child { font-family: var(--font-serif); font-style: italic; color: var(--color-sage-deep); }
</style>
