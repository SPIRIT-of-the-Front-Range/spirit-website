---
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import PullQuote from '../components/editorial/PullQuote.astro';
import { getEntry } from 'astro:content';
import { basePath, resolveLink } from '../lib/paths';
import { mdToHtml, mdToInline } from '../lib/markdown';

const entry = await getEntry('pages', 'donate');
if (!entry) throw new Error('Missing src/content/pages/donate.md');
const { seo, cover, spreads, pullQuote } = entry.data;

const settings = await getEntry('settings', 'site');
if (!settings) throw new Error('Missing src/content/settings/site.md');
const everyOrgUrl = settings.data.donation.url;
const everyOrgReady = settings.data.donation.ready;
---

<Base title={seo.title} description={seo.description}>

  <PageCover
    folio="08"
    sectionLabel="Funding"
    eyebrow={cover.eyebrow}
    title={cover.title}
    italicTitle={cover.italicTitle}
    subtitle={cover.subtitle}
    imageSrc={basePath(cover.imageSrc)}
    imageAlt={cover.imageAlt}
    plate=""
    plateCaption={cover.plateCaption}
    treatment={cover.treatment}
    brightness={cover.brightness}
  >
    {everyOrgReady && (
      <a
        slot="cta"
        href={everyOrgUrl}
        rel="noopener noreferrer"
        target="_blank"
        class="btn-ink !py-4 !px-6 !text-sm"
        style="background: #F2EAD8; color: #1F1E1B; border-color: #F2EAD8;"
      >
        {cover.donateCtaLabel}
      </a>
    )}
  </PageCover>

  {/* OPENING */}
  {spreads?.roots && (
    <Spread folio="08.1" section={spreads.roots.sectionLabel} bg="bone">
      <div class="px-5 lg:px-12 py-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-12 items-start">

          <div class="col-span-12 lg:col-span-3 lg:sticky lg:top-8 self-start space-y-5">
            <span class="folio-num text-7xl text-clay-deep">08.i</span>
            <Marginalia number="01">
              <Fragment set:html={mdToInline(spreads.roots.marginaliaPrimary)} />
            </Marginalia>
            <Marginalia>
              <Fragment set:html={mdToInline(spreads.roots.marginaliaSecondary)} />
            </Marginalia>
          </div>

          <div class="col-span-12 lg:col-span-9 text-body-lg text-ink leading-snug">
            <div class="rule-double mb-6"></div>
            <p class="eyebrow mb-3">{spreads.roots.eyebrow}</p>
            <h2 class="display-m text-ink leading-[1.0] mb-8 max-w-3xl">
              {spreads.roots.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.roots.italicHeading}</span>{spreads.roots.headingTail && (<Fragment> {spreads.roots.headingTail}</Fragment>)}
            </h2>
            <div class="dropcap space-y-5 max-w-3xl">
              <Fragment set:html={mdToHtml(spreads.roots.body)} />
            </div>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* CASCADE */}
  {spreads?.cascade && (
    <Spread folio="08.2" section={spreads.cascade.sectionLabel} bg="ink" class="border-y-2 border-ink">
      <div class="px-5 lg:px-12 py-section on-dark">
        <div class="rule-bold mb-6" style="background:#E8B58A; height:3px;"></div>
        <p class="eyebrow mb-3" style="color:#E8B58A;">{spreads.cascade.eyebrow}</p>
        <h2 class="display-l mb-12 max-w-3xl leading-[1.0]" style="color:#F7EFD8;">
          {spreads.cascade.heading} <span class="italic font-serif font-light" style="font-weight:300; color:#E8B58A;">{spreads.cascade.italicHeading}</span>{spreads.cascade.headingTail && (<Fragment> {spreads.cascade.headingTail}</Fragment>)}
        </h2>

        <ol class="grid md:grid-cols-3 gap-6">
          {spreads.cascade.tiers.map((t) => (
            <li class="border-2 p-6" style="border-color: rgba(247,239,216,0.4); background: rgba(247,239,216,0.03);">
              <div class="flex items-baseline justify-between mb-3">
                <span class="folio-num text-5xl" style="color:#E8B58A;">{t.number}</span>
                <span class="caption" style="color: rgba(247,239,216,0.7);">{t.tier}</span>
              </div>
              <h3 class="font-display font-bold text-h2 leading-tight mb-3" style="color:#F7EFD8;">{t.title}</h3>
              <p class="text-body leading-relaxed" style="color: rgba(247,239,216,0.85);">
                {t.body}
              </p>
            </li>
          ))}
        </ol>
      </div>
    </Spread>
  )}

  {/* DONATE CTA */}
  {spreads?.contribute && (
    <Spread folio="08.3" section={spreads.contribute.sectionLabel} bg="bone-pale">
      <div class="px-5 lg:px-12 py-section">
        <div class="text-center max-w-2xl mx-auto">
          <span class="folio-num text-6xl text-clay-deep mb-4 block">08.iii</span>
          <p class="eyebrow mb-3">{spreads.contribute.eyebrow}</p>
          <h2 class="display-l text-ink leading-[0.95] mb-10">
            {spreads.contribute.heading} <span class="italic font-serif font-light text-clay-deep" style="font-weight:300;">{spreads.contribute.italicHeading}</span>{spreads.contribute.headingTail && (<Fragment> {spreads.contribute.headingTail}</Fragment>)}
          </h2>

          {everyOrgReady ? (
            <a href={everyOrgUrl} rel="noopener noreferrer" target="_blank" class="btn-ink !py-5 !px-8 !text-sm">
              {spreads.contribute.donateCtaLabel}
            </a>
          ) : (
            <div class="paper p-6 lg:p-8 max-w-lg mx-auto">
              <p class="eyebrow mb-3">{spreads.contribute.fallbackEyebrow}</p>
              <p class="font-display font-bold text-h2 text-ink leading-tight mb-3">
                {spreads.contribute.fallbackHeading}
              </p>
              <p class="text-body text-shadow leading-relaxed mb-5">
                {spreads.contribute.fallbackBody}
              </p>
              {(() => {
                const link = resolveLink(spreads.contribute.fallbackCtaHref);
                return (
                  <a href={link.href} rel={link.rel} class="btn-ink">
                    {spreads.contribute.fallbackCtaLabel}
                  </a>
                );
              })()}
            </div>
          )}

          <p class="mt-8 caption text-shadow">
            {spreads.contribute.taxNote}
          </p>
        </div>
      </div>
    </Spread>
  )}

  {/* PULL QUOTE */}
  {pullQuote && (
    <div class="bg-bone py-section">
      <div class="container-narrow">
        <PullQuote>
          {pullQuote.text}
        </PullQuote>
      </div>
    </div>
  )}

</Base>

<style>
  .py-section { padding-block: var(--spacing-section); }
</style>
