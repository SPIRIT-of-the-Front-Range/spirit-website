---
import Base from '../layouts/Base.astro';
import PageCover from '../components/editorial/PageCover.astro';
import Spread from '../components/editorial/Spread.astro';
import CatalogEntry from '../components/editorial/CatalogEntry.astro';
import Marginalia from '../components/editorial/Marginalia.astro';
import { getCollection, render, getEntry } from 'astro:content';
import { basePath } from '../lib/paths';
import { mdToInline } from '../lib/markdown';

const entry = await getEntry('pages', 'catalog');
if (!entry) throw new Error('Missing src/content/pages/catalog.md');
const { seo, cover, spreads } = entry.data;

const entries = (await getCollection('catalog')).sort((a, b) => a.data.order - b.data.order);

const renderedEntries = await Promise.all(
  entries.map(async e => {
    const { Content } = await render(e);
    return { entry: e, Content };
  })
);

const byKind = renderedEntries.reduce((acc, { entry: e }) => {
  const k = e.data.kind;
  acc[k] = (acc[k] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
---

<Base title={seo.title} description={seo.description}>

  <PageCover
    folio="05"
    sectionLabel="Catalog"
    eyebrow={cover.eyebrow}
    title={cover.title}
    italicTitle={cover.italicTitle}
    subtitle={cover.subtitle}
    imageSrc={basePath(cover.imageSrc)}
    imageAlt={cover.imageAlt}
    plate=""
    plateCaption={cover.plateCaption}
    treatment={cover.treatment}
    brightness={cover.brightness}
  />

  {/* TABLE OF CONTENTS */}
  {spreads?.sections && (
    <Spread folio="05.0" section={spreads.sections.sectionLabel} bg="bone-pale" class="border-y border-ink">
      <div class="px-5 lg:px-12 py-12 lg:py-16">
        <div class="grid grid-cols-12 items-baseline gap-6">
          <div class="col-span-12 lg:col-span-4">
            <span class="folio-num text-6xl text-clay-deep">05.0</span>
            <p class="eyebrow mt-3">{spreads.sections.eyebrow}</p>
          </div>
          <div class="col-span-12 lg:col-span-8">
            <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-4 caption text-ink">
              {Object.entries(byKind).map(([kind, count]) => (
                <li class="flex items-baseline justify-between border-b border-rule pb-1">
                  <span class="font-bold text-clay-deep">●  {kind}</span>
                  <span class="text-shadow">{String(count).padStart(2,'0')}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </Spread>
  )}

  {/* CATALOG ENTRIES */}
  {spreads?.entries && (
    <Spread folio="05.1" section={spreads.entries.sectionLabel} bg="bone">
      <div class="px-5 lg:px-12 pt-section pb-section">
        <div class="grid grid-cols-12 gap-6 lg:gap-10">

          <aside class="col-span-12 lg:col-span-3 lg:sticky lg:top-8 self-start space-y-5">
            <Marginalia number="01">
              <Fragment set:html={mdToInline(spreads.entries.marginaliaPrimary)} />
            </Marginalia>
            <Marginalia>
              <Fragment set:html={mdToInline(spreads.entries.marginaliaSecondary)} />
            </Marginalia>
            <Marginalia>
              ★ Items in this issue: <strong class="text-clay-deep">{renderedEntries.length}</strong>.
            </Marginalia>
          </aside>

          <div class="col-span-12 lg:col-span-9">
            <div class="rule-bold mb-2"></div>
            <div class="space-y-4">
              {renderedEntries.map(({ entry: e, Content }, i) => (
                <CatalogEntry
                  number={i + 1}
                  title={e.data.title}
                  kind={e.data.kind}
                  source={e.data.source}
                  url={e.data.url}
                  price={e.data.price}
                  curator={e.data.curator}
                  tone={e.data.tone}
                >
                  <div class="catalog-prose">
                    <Content />
                  </div>
                </CatalogEntry>
              ))}
            </div>
            <div class="rule-bold mt-2"></div>

            <p class="text-center mt-12 caption text-shadow">
              {spreads.entries.issueFooter}
            </p>
          </div>
        </div>
      </div>
    </Spread>
  )}

</Base>

<style>
  .pt-section { padding-top: var(--spacing-section); }
  .pb-section { padding-bottom: var(--spacing-section); }
  .py-section { padding-block: var(--spacing-section); }
  .catalog-prose :global(p) { margin-block: 0.4rem; }
  .catalog-prose :global(p:first-child) { margin-top: 0; }
  .catalog-prose :global(em) { font-style: italic; color: var(--color-clay-deep); }
  .catalog-prose :global(strong) { font-weight: 700; color: var(--color-ink); }
</style>
