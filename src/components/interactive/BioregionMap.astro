---
// Simple SVG map of the Front Range corridor with marker points
// Scaled abstraction: not geographically precise — feels like an almanac map
interface MapPoint {
  x: number;
  y: number;
  name: string;
  kind: 'city' | 'watershed' | 'partner';
}

const points: MapPoint[] = [
  { x: 320, y: 90,  name: 'Fort Collins', kind: 'city' },
  { x: 290, y: 180, name: 'Boulder',      kind: 'city' },
  { x: 360, y: 240, name: 'Denver',       kind: 'city' },
  { x: 310, y: 330, name: 'Colorado Springs', kind: 'city' },
  { x: 340, y: 400, name: 'Pueblo',       kind: 'city' },
  { x: 220, y: 130, name: 'Cache la Poudre', kind: 'watershed' },
  { x: 200, y: 220, name: 'Boulder Creek',  kind: 'watershed' },
  { x: 240, y: 280, name: 'South Platte',   kind: 'watershed' },
  { x: 230, y: 360, name: 'Arkansas',       kind: 'watershed' },
];
---

<figure class="bioregion-map relative">
  <svg viewBox="0 0 600 480" preserveAspectRatio="xMidYMid meet" class="w-full h-auto" aria-label="Map of the Colorado Front Range corridor with major cities, watersheds, and partner locations.">
    <defs>
      <pattern id="paper-grain" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
        <rect width="80" height="80" fill="#F2EAD8" />
        <circle cx="10" cy="20" r="0.4" fill="#4A4A45" opacity="0.2" />
        <circle cx="40" cy="50" r="0.4" fill="#4A4A45" opacity="0.2" />
        <circle cx="70" cy="30" r="0.4" fill="#4A4A45" opacity="0.2" />
        <circle cx="20" cy="70" r="0.4" fill="#4A4A45" opacity="0.2" />
      </pattern>
    </defs>

    {/* Paper background */}
    <rect width="600" height="480" fill="url(#paper-grain)" />

    {/* Frame */}
    <rect x="20" y="20" width="560" height="440" fill="none" stroke="#2A2A28" stroke-width="1.4" />
    <rect x="26" y="26" width="548" height="428" fill="none" stroke="#2A2A28" stroke-width="0.6" />

    {/* Mountains backdrop (West) — soft shape */}
    <path d="M 60 60 L 60 460 L 220 460 Q 200 380, 240 320 Q 200 260, 230 200 Q 180 130, 200 60 Z"
          fill="#9DA47A" opacity="0.45" />
    <path d="M 60 60 L 60 460 L 180 460 Q 160 380, 200 320 Q 170 260, 190 200 Q 150 130, 170 60 Z"
          fill="#7E8158" opacity="0.55" />

    {/* Plains (East) — flat grass */}
    <path d="M 380 60 L 580 60 L 580 460 L 380 460 Z" fill="#C5BE92" opacity="0.35" />

    {/* Front Range corridor center spine */}
    <line x1="290" y1="60" x2="320" y2="460" stroke="#2A2A28" stroke-width="1" stroke-dasharray="4 4" opacity="0.5" />

    {/* Cities & partners */}
    {points.map(p => (
      p.kind === 'city' ? (
        <g class="map-point" data-kind={p.kind}>
          <circle cx={p.x} cy={p.y} r="5" fill="#B8704D" stroke="#2A2A28" stroke-width="1.2" />
          <text x={p.x + 12} y={p.y + 4} font-family="JetBrains Mono, monospace" font-size="10" font-weight="700" fill="#2A2A28">
            {p.name}
          </text>
        </g>
      ) : (
        <g class="map-point" data-kind={p.kind}>
          <path d={`M ${p.x - 5} ${p.y} L ${p.x} ${p.y - 5} L ${p.x + 5} ${p.y} L ${p.x} ${p.y + 5} Z`} fill="#5C7E8A" />
          <text x={p.x + 10} y={p.y + 3} font-family="JetBrains Mono, monospace" font-size="9" font-style="italic" fill="#3E5C68">
            {p.name}
          </text>
        </g>
      )
    ))}

    {/* Compass rose */}
    <g transform="translate(530 410)">
      <circle r="22" fill="none" stroke="#2A2A28" stroke-width="0.8" />
      <line x1="0" y1="-22" x2="0" y2="22" stroke="#2A2A28" stroke-width="0.8" />
      <line x1="-22" y1="0" x2="22" y2="0" stroke="#2A2A28" stroke-width="0.8" />
      <text y="-26" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" font-weight="700" fill="#2A2A28">N</text>
      <text x="28" y="3" text-anchor="start" font-family="JetBrains Mono, monospace" font-size="8" fill="#2A2A28">E</text>
      <text y="32" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#2A2A28">S</text>
      <text x="-28" y="3" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="8" fill="#2A2A28">W</text>
    </g>

    {/* Title block — positioned safely within the inner frame */}
    <g transform="translate(40 415)">
      <text font-family="Bricolage Grotesque Variable, sans-serif" font-size="14" font-weight="700" fill="#2A2A28">
        THE FRONT RANGE CORRIDOR
      </text>
      <text y="14" font-family="JetBrains Mono, monospace" font-size="9" fill="#4A4A45">
        a transitional ecology where mountains meet grasslands
      </text>
    </g>

    {/* Legend */}
    <g transform="translate(420 80)" font-family="JetBrains Mono, monospace" font-size="9" fill="#2A2A28">
      <text font-weight="700" letter-spacing="0.12em">LEGEND</text>
      <circle cx="6" cy="20" r="4" fill="#B8704D" stroke="#2A2A28" stroke-width="1" />
      <text x="16" y="23">city</text>
      <path d="M 1 35 L 6 30 L 11 35 L 6 40 Z" fill="#5C7E8A" />
      <text x="16" y="38">watershed</text>
    </g>
  </svg>
  <figcaption class="mt-3 font-mono text-[0.72rem] uppercase tracking-[0.16em] text-shadow text-center">
    fig. 1 · the corridor
  </figcaption>
</figure>
