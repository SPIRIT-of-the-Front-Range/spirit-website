---
// Front Range corridor panorama — hand-drawn SVG
// West (mountains) → East (high plains)
// Used as the home hero. Layered parallax via scroll-driven CSS animations.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`panorama relative w-full overflow-hidden ${className}`}>
  <svg
    viewBox="0 0 1600 700"
    preserveAspectRatio="xMidYMid slice"
    class="w-full h-full block"
    aria-label="A hand-drawn panorama of the Colorado Front Range — snowy peaks giving way to foothills, then high plains stretching east."
    role="img"
  >
    <defs>
      {/* Sun / sky gradient */}
      <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"  stop-color="#E2D8C0" />
        <stop offset="40%" stop-color="#EFE6CD" />
        <stop offset="100%" stop-color="#F2EAD8" />
      </linearGradient>

      {/* Distant peaks — palest */}
      <linearGradient id="peaks-far" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#9CABB2" />
        <stop offset="100%" stop-color="#B6C3CB" />
      </linearGradient>

      {/* Mid peaks */}
      <linearGradient id="peaks-mid" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#5C7E8A" />
        <stop offset="100%" stop-color="#7A95A0" />
      </linearGradient>

      {/* Foothills */}
      <linearGradient id="hills" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#7E8158" />
        <stop offset="100%" stop-color="#9DA47A" />
      </linearGradient>

      {/* Grass */}
      <linearGradient id="grass" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#A8AB7A" />
        <stop offset="100%" stop-color="#C5BE92" />
      </linearGradient>

      {/* Newsprint hatch pattern for the rocks */}
      <pattern id="hatch" patternUnits="userSpaceOnUse" width="4" height="4" patternTransform="rotate(45)">
        <line x1="0" y1="0" x2="0" y2="4" stroke="#2A2A28" stroke-width="0.6" opacity="0.18" />
      </pattern>

      {/* Sun */}
      <radialGradient id="sun" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#E8A77C" />
        <stop offset="60%" stop-color="#D08A5D" stop-opacity="0.85" />
        <stop offset="100%" stop-color="#B8704D" stop-opacity="0" />
      </radialGradient>
    </defs>

    {/* Sky */}
    <rect width="1600" height="700" fill="url(#sky)" />

    {/* Sun */}
    <circle cx="380" cy="220" r="110" fill="url(#sun)" />
    <circle cx="380" cy="220" r="56" fill="#B8704D" opacity="0.78" />

    {/* Distant snow peaks (West) */}
    <g class="layer-far">
      <path d="
        M 0 460
        L 60 380 L 110 410 L 160 320 L 210 360
        L 260 280 L 310 330 L 360 250 L 410 310
        L 470 230 L 520 290 L 580 240 L 640 280
        L 700 320 L 760 280 L 820 340
        L 1600 460 Z"
        fill="url(#peaks-far)"
      />
      {/* Snow caps */}
      <path d="M 250 295 L 260 280 L 275 290 Z" fill="#F2EAD8" />
      <path d="M 350 265 L 360 250 L 375 260 Z" fill="#F2EAD8" />
      <path d="M 460 245 L 470 230 L 485 240 Z" fill="#F2EAD8" />
      <path d="M 570 255 L 580 240 L 595 250 Z" fill="#F2EAD8" />
    </g>

    {/* Mid peaks */}
    <g class="layer-mid">
      <path d="
        M 0 540
        L 80 470 L 140 500 L 200 420 L 270 470
        L 340 380 L 400 440 L 480 360 L 540 410
        L 620 450 L 700 400 L 780 460 L 860 430
        L 1600 540 Z"
        fill="url(#peaks-mid)"
      />
      <rect x="0" y="380" width="1000" height="180" fill="url(#hatch)" />
    </g>

    {/* Flatirons — slanted slabs (signature Boulder formation) */}
    <g class="layer-flatirons" transform="translate(380 380)">
      <path d="M 0 180 L 70 0 L 100 30 L 100 180 Z" fill="#B8704D" />
      <path d="M 110 180 L 175 20 L 200 50 L 200 180 Z" fill="#A85F3D" />
      <path d="M 210 180 L 270 40 L 290 70 L 290 180 Z" fill="#B8704D" />
      {/* Hatch overlay on flatirons */}
      <path d="M 0 180 L 70 0 L 100 30 L 100 180 Z" fill="url(#hatch)" />
      <path d="M 110 180 L 175 20 L 200 50 L 200 180 Z" fill="url(#hatch)" />
      <path d="M 210 180 L 270 40 L 290 70 L 290 180 Z" fill="url(#hatch)" />
    </g>

    {/* Foothills */}
    <g class="layer-hills">
      <path d="
        M 0 600
        Q 100 540, 200 580
        T 400 570
        T 600 580
        T 800 560
        T 1000 590
        T 1200 580
        T 1400 600
        T 1600 590
        L 1600 700 L 0 700 Z"
        fill="url(#hills)"
      />
    </g>

    {/* Creek — winding blue */}
    <g class="layer-creek">
      <path d="
        M 600 700
        C 640 660, 700 670, 740 640
        C 780 610, 850 620, 900 590
        C 950 560, 1020 570, 1080 540
        L 1090 545
        C 1030 575, 960 565, 910 595
        C 860 625, 790 615, 750 645
        C 710 675, 650 665, 610 705 Z"
        fill="#5C7E8A"
        opacity="0.85"
      />
      <path d="
        M 600 700
        C 640 660, 700 670, 740 640
        C 780 610, 850 620, 900 590
        C 950 560, 1020 570, 1080 540"
        fill="none"
        stroke="#3E5C68"
        stroke-width="1.5"
      />
    </g>

    {/* Grasslands (East) — open plains */}
    <g class="layer-grass">
      <path d="
        M 800 700
        L 800 660
        Q 1000 640, 1200 660
        T 1600 650
        L 1600 700 Z"
        fill="url(#grass)"
      />

      {/* Tall grass strokes */}
      {Array.from({ length: 60 }).map((_, i) => {
        const x = 820 + i * 13 + (i % 3) * 4;
        const h = 10 + (i % 5) * 4;
        return (
          <line x1={x} y1={680} x2={x + 1} y2={680 - h} stroke="#7E8158" stroke-width="0.8" opacity="0.7" />
        );
      })}
    </g>

    {/* Birds — small ink marks in the sky */}
    <g class="layer-birds" fill="none" stroke="#2A2A28" stroke-width="1.4" stroke-linecap="round" opacity="0.55">
      <path d="M 900 180 q 6 -6 12 0 q 6 -6 12 0" />
      <path d="M 970 160 q 4 -4 8 0 q 4 -4 8 0" />
      <path d="M 1050 200 q 5 -5 10 0 q 5 -5 10 0" />
      <path d="M 1180 150 q 5 -5 10 0 q 5 -5 10 0" />
    </g>

    {/* Cardinal markers — west / east */}
    <g class="layer-text" font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="0.18em" fill="#4A4A45">
      <text x="40" y="40" font-weight="700">W ⟵ MOUNTAINS</text>
      <text x="1430" y="40" font-weight="700" text-anchor="end">PLAINS ⟶ E</text>
      <text x="40" y="680" font-weight="400" opacity="0.7">14 200 ft.</text>
      <text x="1430" y="680" font-weight="400" opacity="0.7" text-anchor="end">5 100 ft.</text>
    </g>
  </svg>
</div>

<style>
  /* Subtle scroll-driven parallax — pans the panorama as user scrolls */
  @supports (animation-timeline: view()) {
    .panorama .layer-far {
      animation: pan-far linear both;
      animation-timeline: view();
      animation-range: cover 0% cover 100%;
    }
    .panorama .layer-mid {
      animation: pan-mid linear both;
      animation-timeline: view();
      animation-range: cover 0% cover 100%;
    }
    .panorama .layer-creek {
      animation: pan-creek linear both;
      animation-timeline: view();
      animation-range: cover 0% cover 100%;
    }
    @keyframes pan-far    { from { transform: translateX(20px);  } to { transform: translateX(-20px); } }
    @keyframes pan-mid    { from { transform: translateX(40px);  } to { transform: translateX(-40px); } }
    @keyframes pan-creek  { from { transform: translateX(0);     } to { transform: translateX(-30px); } }
  }
</style>
