---
// Whole Earth–style catalog entry
interface Props {
  title: string;
  kind: string;       // book | organization | tool | practice | place | podcast
  source?: string;
  url?: string;
  price?: string;
  curator?: string;
  number?: number | string;
  tone?: 'clay' | 'creek' | 'sage' | 'grass';
}
const { title, kind, source, url, price, curator, number, tone = 'clay' } = Astro.props;

const toneClass: Record<string, string> = {
  clay: 'text-clay-deep',
  creek: 'text-creek-deep',
  sage: 'text-sage-deep',
  grass: 'text-grass-deep',
};
---

<article class="catalog-entry grid grid-cols-12 gap-4 lg:gap-6 group">
  {/* Left margin: number + kind */}
  <aside class="col-span-12 lg:col-span-2 flex lg:flex-col gap-3 lg:gap-1 items-baseline lg:items-start">
    {number && <span class={`num-badge ${toneClass[tone]} text-base`}>N° {number}</span>}
    <span class="font-mono text-micro uppercase tracking-[0.18em] text-shadow">{kind}</span>
  </aside>

  {/* Main: title + curator note */}
  <div class="col-span-12 lg:col-span-7">
    {url ? (
      <h3 class="display-m text-ink mb-2 leading-tight">
        <a href={url} class="no-underline hover:text-clay-deep transition-colors" rel="noopener" target="_blank">
          {title}
          <span class="inline-block ml-1 text-base align-baseline opacity-60" aria-hidden="true">↗</span>
        </a>
      </h3>
    ) : (
      <h3 class="display-m text-ink mb-2 leading-tight">{title}</h3>
    )}

    <div class="text-body text-shadow leading-relaxed">
      <slot />
    </div>

    {curator && (
      <p class="mt-3 font-mono text-micro uppercase tracking-[0.14em] text-shadow">
        — Curated by <span class="text-clay-deep">{curator}</span>
      </p>
    )}
  </div>

  {/* Right margin: source + price */}
  <aside class="col-span-12 lg:col-span-3 lg:text-right">
    {source && (
      <p class="font-mono text-caption text-shadow leading-tight mb-1">{source}</p>
    )}
    {price && (
      <p class={`font-mono text-caption font-bold ${toneClass[tone]}`}>{price}</p>
    )}
  </aside>
</article>
