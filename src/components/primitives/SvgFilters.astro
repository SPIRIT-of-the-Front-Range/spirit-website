---
// Inline SVG filters used by .duotone-* classes globally
// Filter math: feColorMatrix flattens to luminance, feComponentTransfer remaps via tableValues
// Each table goes from [shadow color] to [highlight color] in linear-RGB
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="0" height="0"
  style="position:absolute;width:0;height:0;overflow:hidden;pointer-events:none"
  aria-hidden="true"
>
  <defs>
    <!-- DUO · CLAY (rust shadow → cream highlight, NOT bone) -->
    <filter id="duo-clay" color-interpolation-filters="sRGB">
      <feColorMatrix type="matrix" values="
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0    0    0    1 0"/>
      <feComponentTransfer>
        <feFuncR type="table" tableValues="0.18 0.85"/>
        <feFuncG type="table" tableValues="0.10 0.70"/>
        <feFuncB type="table" tableValues="0.06 0.52"/>
      </feComponentTransfer>
    </filter>

    <!-- DUO · CLAY-DEEP (deeper, more saturated rust) -->
    <filter id="duo-clay-deep" color-interpolation-filters="sRGB">
      <feColorMatrix type="matrix" values="
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0    0    0    1 0"/>
      <feComponentTransfer>
        <feFuncR type="table" tableValues="0.22 0.78"/>
        <feFuncG type="table" tableValues="0.10 0.44"/>
        <feFuncB type="table" tableValues="0.06 0.26"/>
      </feComponentTransfer>
    </filter>

    <!-- DUO · SAGE (deep moss → soft sage) -->
    <filter id="duo-sage" color-interpolation-filters="sRGB">
      <feColorMatrix type="matrix" values="
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0    0    0    1 0"/>
      <feComponentTransfer>
        <feFuncR type="table" tableValues="0.16 0.78"/>
        <feFuncG type="table" tableValues="0.22 0.82"/>
        <feFuncB type="table" tableValues="0.14 0.62"/>
      </feComponentTransfer>
    </filter>

    <!-- DUO · CREEK (deep slate → soft slate-blue) -->
    <filter id="duo-creek" color-interpolation-filters="sRGB">
      <feColorMatrix type="matrix" values="
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0    0    0    1 0"/>
      <feComponentTransfer>
        <feFuncR type="table" tableValues="0.12 0.70"/>
        <feFuncG type="table" tableValues="0.20 0.80"/>
        <feFuncB type="table" tableValues="0.28 0.86"/>
      </feComponentTransfer>
    </filter>

    <!-- DUO · INK (warm-black → warm cream) -->
    <filter id="duo-ink" color-interpolation-filters="sRGB">
      <feColorMatrix type="matrix" values="
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0.34 0.50 0.16 0 0
        0    0    0    1 0"/>
      <feComponentTransfer>
        <feFuncR type="table" tableValues="0.10 0.86"/>
        <feFuncG type="table" tableValues="0.10 0.82"/>
        <feFuncB type="table" tableValues="0.08 0.72"/>
      </feComponentTransfer>
    </filter>
  </defs>
</svg>
